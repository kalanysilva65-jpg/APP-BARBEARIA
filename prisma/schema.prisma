// Modelo de dados da barbearia (MULTI-BARBEARIA / SaaS).
// Cada registro pertence a uma Barbearia (o "tenant"), identificada pelo `slug`
// (que vira o subdomínio: <slug>.seuapp.com). O painel-mestre (dono do sistema)
// enxerga todas as barbearias; cada barbearia só enxerga os próprios dados.
//
// Os nomes das tabelas/colunas no banco ficam em português (snake_case) via @map.
// Valores monetários são guardados como INTEIROS em centavos (ex.: 4000 = R$ 40,00)
// para evitar erros de arredondamento de ponto flutuante; a formatação acontece na view.

generator client {
  provider = "prisma-client-js"
  // Gera os motores de query para as plataformas Linux mais prováveis em
  // produção (Hostinger/CloudLinux é RHEL; cobrimos Debian e musl por garantia).
  // Sem isso, o motor gerado no build pode ser incompatível com o runtime e
  // crashar nativamente na primeira query. "native" mantém o dev local.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.1.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Tenant do sistema: uma barbearia assinante. O `slug` é o subdomínio.
model Barbearia {
  id       Int      @id @default(autoincrement())
  nome     String
  slug     String   @unique // subdomínio: <slug>.seuapp.com
  ativo    Boolean  @default(true)
  // Endereço e coordenadas (para a busca "perto de você" no app do cliente).
  // lat/lng são preenchidos automaticamente ao salvar o endereço (geocodificação).
  endereco  String?
  latitude  Float?
  longitude Float?
  capaUrl   String?  @map("capa_url") // foto de capa do hero da Home (em /uploads)
  criadoEm DateTime @default(now()) @map("criado_em")

  usuarios           Usuario[]
  horariosTrabalho   HorarioTrabalho[]
  bloqueios          Bloqueio[]
  categoriasServico  CategoriaServico[]
  servicos           Servico[]
  agendamentos       Agendamento[]
  clientes           Cliente[]
  planos             Plano[]
  clientePlanos      ClientePlano[]
  categoriasEstoque  CategoriaEstoque[]
  estoque            Estoque[]
  categoriasCaixa    CategoriaCaixa[]
  caixa              Caixa[]
  configuracoes      Configuracao[]

  @@map("barbearias")
}

/// Equipe / barbeiros (admin + funcionários) OU o dono do sistema.
/// - papel "dono": super-admin do SaaS, sem barbearia (barbeariaId nulo).
/// - papel "admin"/"funcionario": pertence a uma barbearia. Todos agendáveis.
model Usuario {
  id          Int      @id @default(autoincrement())
  barbeariaId Int?     @map("barbearia_id") // nulo apenas para o dono do sistema
  nome        String
  email       String
  senhaHash   String   @map("senha_hash")
  fotoUrl     String?  @map("foto_url") // foto do barbeiro (em /uploads)
  papel       String // "dono" | "admin" | "funcionario"
  ativo       Boolean  @default(true)
  comissaoPercentual Float @default(50) @map("comissao_percentual") // % de comissão do barbeiro
  criadoEm  DateTime @default(now()) @map("criado_em")

  barbearia        Barbearia? @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  horariosTrabalho HorarioTrabalho[]
  bloqueios        Bloqueio[]
  agendamentos     Agendamento[]

  // E-mail único DENTRO de cada barbearia (o mesmo e-mail pode existir em barbearias diferentes).
  @@unique([barbeariaId, email])
  @@map("usuarios")
}

/// Jornada de trabalho de cada barbeiro (um registro por dia da semana).
model HorarioTrabalho {
  id          Int     @id @default(autoincrement())
  barbeariaId Int     @map("barbearia_id")
  usuarioId   Int     @map("usuario_id")
  diaSemana   Int     @map("dia_semana") // 0=domingo ... 6=sábado
  horaInicio  String  @map("hora_inicio") // ex.: "09:00"
  horaFim     String  @map("hora_fim") // ex.: "20:00"
  trabalha    Boolean @default(true) // false = folga nesse dia

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("horarios_trabalho")
}

/// Bloqueios manuais de horário (almoço, compromisso, dia fechado etc.).
model Bloqueio {
  id          Int      @id @default(autoincrement())
  barbeariaId Int      @map("barbearia_id")
  usuarioId   Int      @map("usuario_id")
  data        DateTime // dia do bloqueio (00:00)
  horaInicio  String   @map("hora_inicio")
  horaFim     String   @map("hora_fim")
  motivo      String? // opcional

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("bloqueios")
}

/// Categorias dos serviços/produtos do catálogo (configuráveis manualmente).
model CategoriaServico {
  id          Int       @id @default(autoincrement())
  barbeariaId Int       @map("barbearia_id")
  nome        String
  servicos    Servico[]

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("categorias_servico")
}

/// Serviços e produtos que o cliente agenda / a equipe adiciona ao atendimento.
model Servico {
  id          Int     @id @default(autoincrement())
  barbeariaId Int     @map("barbearia_id")
  nome        String
  descricao   String? // descrição curta exibida no card de agendamento
  categoriaId Int?    @map("categoria_id")
  valor       Int // centavos
  duracaoMin  Int     @map("duracao_min") // usado para calcular os horários
  fotoUrl     String? @map("foto_url") // caminho da imagem em /uploads
  ativo              Boolean @default(true)
  ehProduto          Boolean @default(false) @map("eh_produto") // produto x serviço
  comissaoPercentual Float   @default(10) @map("comissao_percentual") // % de comissão sobre o produto

  barbearia Barbearia         @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  categoria CategoriaServico? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  itens     AgendamentoItem[]
  planos    Plano[]

  @@map("servicos")
}

/// Agendamentos do cliente, vinculados a um barbeiro específico (obrigatório).
model Agendamento {
  id              Int      @id @default(autoincrement())
  barbeariaId     Int      @map("barbearia_id")
  usuarioId       Int      @map("usuario_id") // barbeiro escolhido
  clienteNome     String   @map("cliente_nome")
  clienteEmail    String?  @map("cliente_email")
  clienteTelefone String   @map("cliente_telefone")
  data            DateTime // dia do agendamento (00:00)
  horaInicio      String   @map("hora_inicio")
  status          String   @default("agendado") // agendado | concluido | cancelado
  valorTotal      Int      @default(0) @map("valor_total") // centavos, recalculado pelos itens
  clienteId       Int?     @map("cliente_id") // vínculo opcional ao cadastro LOCAL (CRM) da barbearia
  contaClienteId  Int?     @map("conta_cliente_id") // conta GLOBAL do app do cliente (marketplace)
  clientePlanoId  Int?     @map("cliente_plano_id") // assinatura usada (agendamento via plano)
  criadoEm        DateTime @default(now()) @map("criado_em")

  barbearia    Barbearia         @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  usuario      Usuario           @relation(fields: [usuarioId], references: [id])
  cliente      Cliente?          @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  contaCliente ContaCliente?     @relation(fields: [contaClienteId], references: [id], onDelete: SetNull)
  clientePlano ClientePlano?     @relation(fields: [clientePlanoId], references: [id], onDelete: SetNull)
  itens        AgendamentoItem[]
  caixa        Caixa[]

  @@map("agendamentos")
}

/// Conta de cliente do MARKETPLACE (app do cliente). GLOBAL: um login por e-mail
/// funciona em QUALQUER barbearia. NÃO confundir com `Cliente`, que é o cadastro
/// LOCAL (CRM) de cada barbearia, chaveado por telefone. Ao agendar por uma conta,
/// o sistema garante um `Cliente` local correspondente para o painel/planos daquela
/// barbearia continuarem funcionando (o `Agendamento` guarda os dois vínculos).
model ContaCliente {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique // único no sistema inteiro (não por barbearia)
  senhaHash String   @map("senha_hash")
  telefone  String? // normalizado: apenas dígitos
  fotoUrl   String?  @map("foto_url")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  agendamentos Agendamento[]

  @@map("contas_cliente")
}

/// Cadastro de clientes. Telefone guardado normalizado (só dígitos), único por barbearia.
model Cliente {
  id             Int       @id @default(autoincrement())
  barbeariaId    Int       @map("barbearia_id")
  nome           String
  telefone       String // normalizado: apenas dígitos
  dataNascimento DateTime? @map("data_nascimento") // opcional
  criadoEm       DateTime  @default(now()) @map("criado_em")

  barbearia    Barbearia      @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  planos       ClientePlano[]

  // Telefone único DENTRO de cada barbearia.
  @@unique([barbeariaId, telefone])
  @@map("clientes")
}

/// Modelos de plano (assinatura) configurados pelo admin.
/// limitado = nº de usos; ilimitado = sem limite de usos.
/// diasSemana: dias em que o plano pode ser usado (0=dom .. 6=sáb, separados por vírgula).
model Plano {
  id           Int      @id @default(autoincrement())
  barbeariaId  Int      @map("barbearia_id")
  nome         String
  tipo         String // "limitado" | "ilimitado"
  usos         Int? // nº de usos (apenas para o tipo limitado)
  validadeDias Int      @default(30) @map("validade_dias") // validade em dias a partir da aquisição
  valor        Int      @default(0) // centavos; entra no caixa quando o cliente adquire
  ativo        Boolean  @default(true)
  servicoId    Int?     @map("servico_id") // serviço coberto pelo plano (null = qualquer)
  diasSemana   String   @default("0,1,2,3,4,5,6") @map("dias_semana")
  criadoEm     DateTime @default(now()) @map("criado_em")

  barbearia   Barbearia      @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  servico     Servico?       @relation(fields: [servicoId], references: [id], onDelete: SetNull)
  assinaturas ClientePlano[]

  @@map("planos")
}

/// Assinatura: vincula um plano a um cliente, com validade e usos restantes.
model ClientePlano {
  id            Int      @id @default(autoincrement())
  barbeariaId   Int      @map("barbearia_id")
  clienteId     Int      @map("cliente_id")
  planoId       Int      @map("plano_id")
  dataInicio    DateTime @map("data_inicio")
  dataFim       DateTime @map("data_fim")
  usosRestantes Int?     @map("usos_restantes") // null = ilimitado
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")

  barbearia    Barbearia     @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  plano        Plano         @relation(fields: [planoId], references: [id])
  agendamentos Agendamento[]

  @@map("cliente_planos")
}

/// Itens (serviços/produtos) de cada agendamento. A equipe adiciona/remove aqui.
/// Não tem barbeariaId próprio: pertence sempre ao Agendamento (que é da barbearia).
model AgendamentoItem {
  id            Int @id @default(autoincrement())
  agendamentoId Int @map("agendamento_id")
  servicoId     Int @map("servico_id")
  valorUnitario Int @map("valor_unitario") // "congela" o preço no momento do agendamento (centavos)
  quantidade    Int @default(1)

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  servico     Servico     @relation(fields: [servicoId], references: [id])

  @@map("agendamento_itens")
}

/// Categorias dos itens de estoque (configuráveis manualmente).
model CategoriaEstoque {
  id          Int       @id @default(autoincrement())
  barbeariaId Int       @map("barbearia_id")
  nome        String
  itens       Estoque[]

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("categorias_estoque")
}

/// Itens de estoque (insumos internos). Alerta quando quantidade <= quantidadeMinima.
model Estoque {
  id               Int      @id @default(autoincrement())
  barbeariaId      Int      @map("barbearia_id")
  nome             String
  categoriaId      Int?     @map("categoria_id")
  quantidade       Int      @default(0)
  quantidadeMinima Int      @default(0) @map("quantidade_minima") // dispara o alerta
  valorGasto       Int      @default(0) @map("valor_gasto") // custo da compra (centavos)
  atualizadoEm     DateTime @default(now()) @updatedAt @map("atualizado_em")

  barbearia Barbearia         @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  categoria CategoriaEstoque? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  @@map("estoque")
}

/// Categorias das movimentações de caixa (configuráveis manualmente).
model CategoriaCaixa {
  id          Int     @id @default(autoincrement())
  barbeariaId Int     @map("barbearia_id")
  nome        String
  tipo        String // entrada | saida
  lancamentos Caixa[]

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  @@map("categorias_caixa")
}

/// Movimentações de caixa (entradas e saídas).
model Caixa {
  id            Int      @id @default(autoincrement())
  barbeariaId   Int      @map("barbearia_id")
  categoriaId   Int?     @map("categoria_id")
  descricao     String
  valor         Int // centavos
  tipo          String // entrada | saida
  data          DateTime @default(now())
  agendamentoId Int?     @map("agendamento_id") // preenchido se veio de um agendamento concluído

  barbearia   Barbearia       @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)
  categoria   CategoriaCaixa? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  agendamento Agendamento?    @relation(fields: [agendamentoId], references: [id], onDelete: SetNull)

  @@map("caixa")
}

/// Configurações gerais do app (chave/valor) por barbearia.
/// Ex.: caixa_automatico = "false", logo_url, mostrar_powered_by.
model Configuracao {
  id          Int    @id @default(autoincrement())
  barbeariaId Int    @map("barbearia_id")
  chave       String
  valor       String

  barbearia Barbearia @relation(fields: [barbeariaId], references: [id], onDelete: Cascade)

  // Cada chave é única DENTRO de cada barbearia.
  @@unique([barbeariaId, chave])
  @@map("configuracoes")
}
