# Copie este arquivo para .env e ajuste os valores

# Porta do servidor
PORT=3000

# Segredo da sessão (troque por um valor aleatório)
SESSION_SECRET=troque-por-um-segredo-aleatorio

# Banco SQLite (caminho relativo à pasta prisma/)
DATABASE_URL="file:../data/app.db"

# PRODUÇÃO — leia com atenção:
# A pasta do código é RECRIADA a cada "Reimplantar". Se o banco, os uploads e as
# sessões ficarem dentro dela, TUDO é perdido no deploy (clientes, agendamentos,
# fotos). Aponte as duas variáveis abaixo para um diretório FORA do deploy:
#
#   APP_DATA_DIR=/home/SEU_USUARIO/cortavo-data
#   DATABASE_URL="file:/home/SEU_USUARIO/cortavo-data/app.db"
#
# O DATABASE_URL precisa ser um caminho ABSOLUTO: o `prisma migrate deploy` do
# postinstall lê esta variável e resolve caminhos relativos a partir de prisma/.

# Domínio raiz da aplicação em produção (sem "www", sem subdomínio de barbearia).
# Necessário para diferenciar o domínio raiz de um subdomínio de barbearia
# (ex.: andrade.cortavo.com.br). Deixe em branco em desenvolvimento local.
APP_DOMAIN=cortavo.com.br
