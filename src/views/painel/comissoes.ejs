<div class="cabecalho-pagina">
  <h1>Comissões</h1>
  <p class="texto-secundario">
    Serviços pela % de cada barbeiro · só atendimentos concluídos.
  </p>
</div>

<!-- Seletor de período e de barbeiro -->
<div class="card mb-16">
  <div class="comissao-presets">
    <a class="btn btn-secundario btn-sm" href="/painel/comissoes?inicio=<%= presetHoje.inicio %>&fim=<%= presetHoje.fim %>&barbeiro=<%= barbeiroSelecionado %>">Hoje</a>
    <a class="btn btn-secundario btn-sm" href="/painel/comissoes?inicio=<%= presetSemana.inicio %>&fim=<%= presetSemana.fim %>&barbeiro=<%= barbeiroSelecionado %>">Semana</a>
    <a class="btn btn-secundario btn-sm" href="/painel/comissoes?inicio=<%= presetMes.inicio %>&fim=<%= presetMes.fim %>&barbeiro=<%= barbeiroSelecionado %>">Mês</a>
  </div>
  <form method="GET" action="/painel/comissoes" class="form-periodo mt-16">
    <div class="campo">
      <label for="barbeiro">Barbeiro</label>
      <select id="barbeiro" name="barbeiro" onchange="this.form.submit()">
        <option value="todos" <%= barbeiroSelecionado === 'todos' ? 'selected' : '' %>>Todos os barbeiros</option>
        <% barbeiros.forEach(function (b) { %>
          <option value="<%= b.id %>" <%= barbeiroSelecionado === String(b.id) ? 'selected' : '' %>><%= b.nome %></option>
        <% }) %>
      </select>
    </div>
    <div class="campo">
      <label for="inicio">De</label>
      <input id="inicio" type="date" name="inicio" value="<%= inicioStr %>" />
    </div>
    <div class="campo">
      <label for="fim">Até</label>
      <input id="fim" type="date" name="fim" value="<%= fimStr %>" />
    </div>
    <button class="btn btn-primario btn-sm">Aplicar</button>
  </form>
</div>

<!-- Totais gerais -->
<div class="grade-resumo mb-16">
  <div class="card resumo-caixa">
    <div class="resumo-titulo">Faturado (serviços + produtos)</div>
    <div class="resumo-valor-grande"><%= fmtBRL(totalServicos + totalProdutos) %></div>
  </div>
  <div class="card resumo-caixa">
    <div class="resumo-titulo">Comissão total</div>
    <div class="resumo-valor-grande valor-entrada"><%= fmtBRL(totalGeralComissao) %></div>
  </div>
</div>

<!-- Por barbeiro -->
<% grupos.forEach(function (g) { %>
  <div class="card mb-16">
    <div class="comissao-cabecalho">
      <div>
        <h2><%= g.barbeiro.nome %></h2>
        <span class="texto-sutil"><%= g.qtd %> atendimento(s) concluído(s)</span>
      </div>
      <div class="comissao-numeros">
        <div class="comissao-num">
          <span class="texto-sutil">Serviços</span>
          <strong><%= fmtBRL(g.servicosTotal) %></strong>
        </div>
        <div class="comissao-num">
          <span class="texto-sutil">Produtos</span>
          <strong><%= fmtBRL(g.produtosTotal) %></strong>
        </div>
        <div class="comissao-num">
          <span class="texto-sutil">Ticket médio</span>
          <strong><%= fmtBRL(g.ticketMedio) %></strong>
        </div>
        <div class="comissao-num">
          <span class="texto-sutil">Ocupação</span>
          <strong><%= g.ocupacaoPct === null ? '—' : g.ocupacaoPct + '%' %></strong>
        </div>
        <div class="comissao-num">
          <span class="texto-sutil">Comissão</span>
          <strong class="valor-entrada"><%= fmtBRL(g.comissao) %></strong>
        </div>
      </div>
    </div>

    <form method="POST" action="/painel/comissoes/percentual/<%= g.barbeiro.id %>" class="form-percentual mt-16">
      <input type="hidden" name="inicio" value="<%= inicioStr %>" />
      <input type="hidden" name="fim" value="<%= fimStr %>" />
      <input type="hidden" name="barbeiro" value="<%= barbeiroSelecionado %>" />
      <label for="perc-<%= g.barbeiro.id %>">Comissão serviços (%)</label>
      <input id="perc-<%= g.barbeiro.id %>" type="number" name="percentual" step="0.5" min="0" max="100"
             value="<%= g.barbeiro.comissaoPercentual %>" />
      <button class="btn btn-secundario btn-sm">Salvar %</button>
      <span class="texto-sutil">Produtos: <%= comissaoProdutoPct %>% (fixo)</span>
    </form>

    <% if (g.atendimentos.length === 0) { %>
      <p class="texto-secundario mt-16">Nenhum atendimento concluído neste período.</p>
    <% } else { %>
      <div class="tabela-rolagem">
        <table class="tabela mt-16">
          <thead>
            <tr>
              <th>Data</th><th>Cliente</th><th>Itens</th>
              <th class="col-valor">Serviços</th><th class="col-valor">Produtos</th>
            </tr>
          </thead>
          <tbody>
            <% g.atendimentos.forEach(function (a) { %>
              <tr>
                <td><%= fmtData(a.ag.data) %></td>
                <td><%= a.ag.clienteNome %><% if (a.viaPlano) { %> <span class="status">plano</span><% } %></td>
                <td>
                  <% a.itens.forEach(function (it) { %>
                    <span class="<%= it.ehProduto ? 'item-produto' : '' %>">
                      <%= it.nome %><%= it.quantidade > 1 ? ' ×' + it.quantidade : '' %><%= it.ehProduto ? ' (produto)' : '' %>
                    </span><br />
                  <% }) %>
                </td>
                <td class="col-valor"><%= a.servicosSub > 0 ? fmtBRL(a.servicosSub) : '—' %></td>
                <td class="col-valor"><%= a.produtosSub > 0 ? fmtBRL(a.produtosSub) : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% }) %>
