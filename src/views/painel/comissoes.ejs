<div class="cabecalho-pagina">
  <h1>Equipe</h1>
  <p class="texto-secundario">Desempenho e comissões por barbeiro · só atendimentos concluídos.</p>
</div>

<!-- Seletor de período e de barbeiro -->
<div class="card mb-16">
  <div class="comissao-presets">
    <a class="btn btn-secundario btn-sm" href="/painel/comissoes?inicio=<%= presetHoje.inicio %>&fim=<%= presetHoje.fim %>&barbeiro=<%= barbeiroSelecionado %>">Hoje</a>
    <a class="btn btn-secundario btn-sm" href="/painel/comissoes?inicio=<%= presetSemana.inicio %>&fim=<%= presetSemana.fim %>&barbeiro=<%= barbeiroSelecionado %>">Semana</a>
    <a class="btn btn-secundario btn-sm" href="/painel/comissoes?inicio=<%= presetMes.inicio %>&fim=<%= presetMes.fim %>&barbeiro=<%= barbeiroSelecionado %>">Mês</a>
  </div>
  <form method="GET" action="/painel/comissoes" class="form-periodo mt-16">
    <div class="campo">
      <label for="barbeiro">Barbeiro</label>
      <select id="barbeiro" name="barbeiro" onchange="this.form.submit()">
        <option value="todos" <%= barbeiroSelecionado === 'todos' ? 'selected' : '' %>>Todos os barbeiros</option>
        <% barbeiros.forEach(function (b) { %>
          <option value="<%= b.id %>" <%= barbeiroSelecionado === String(b.id) ? 'selected' : '' %>><%= b.nome %></option>
        <% }) %>
      </select>
    </div>
    <div class="campo">
      <label for="inicio">De</label>
      <input id="inicio" type="date" name="inicio" value="<%= inicioStr %>" />
    </div>
    <div class="campo">
      <label for="fim">Até</label>
      <input id="fim" type="date" name="fim" value="<%= fimStr %>" />
    </div>
    <button class="btn btn-primario btn-sm">Aplicar</button>
  </form>
</div>

<!-- Faturado do período -->
<div class="card resumo-caixa mb-16">
  <div class="resumo-titulo">Faturado (serviços + produtos)</div>
  <div class="resumo-valor-grande"><%= fmtBRL(totalServicos + totalProdutos) %></div>
</div>

<!-- Por barbeiro (card compacto, clicável) -->
<% grupos.forEach(function (g) { %>
  <div class="card equipe-mini mb-16" onclick="abrirModalEquipe(<%= g.barbeiro.id %>)">
    <div class="equipe-mini-topo">
      <h2><%= g.barbeiro.nome %></h2>
      <span class="equipe-foto equipe-foto--view">
        <% if (g.barbeiro.fotoUrl) { %>
          <img src="<%= g.barbeiro.fotoUrl %>" alt="Foto de <%= g.barbeiro.nome %>" />
        <% } else { %>
          <span class="equipe-foto-inicial"><%= g.barbeiro.nome.charAt(0).toUpperCase() %></span>
        <% } %>
      </span>
    </div>
    <div class="equipe-metricas">
      <div class="equipe-metrica">
        <div class="equipe-metrica-topo">
          <span class="texto-sutil">Ticket médio</span>
          <strong><%= fmtBRL(g.ticketMedio) %></strong>
        </div>
        <div class="barra-prog"><div class="barra-prog-fill" style="width:<%= Math.round((g.ticketMedio / maxTicket) * 100) %>%"></div></div>
        <span class="equipe-metrica-legenda">Período selecionado</span>
      </div>
      <div class="equipe-metrica">
        <div class="equipe-metrica-topo">
          <span class="texto-sutil">Ocupação</span>
          <strong><%= g.ocupacaoPct === null ? '—' : g.ocupacaoPct + '%' %></strong>
        </div>
        <div class="barra-prog"><div class="barra-prog-fill" style="width:<%= g.ocupacaoPct || 0 %>%"></div></div>
        <span class="equipe-metrica-legenda">Da jornada disponível</span>
      </div>
    </div>
  </div>
<% }) %>

<% if (grupos.length === 0) { %>
  <div class="card"><p class="texto-secundario">Nenhum barbeiro para exibir.</p></div>
<% } %>

<!-- Pop-up de detalhe por barbeiro -->
<% grupos.forEach(function (g) { %>
  <div class="ag-overlay" id="equipe-modal-<%= g.barbeiro.id %>" onclick="if(event.target===this)fecharModal(this)">
    <div class="ag-modal-box">
      <div class="ag-modal-topo equipe-modal-topo">
        <div class="equipe-modal-nome">
          <div class="ag-modal-nome"><%= g.barbeiro.nome %></div>
          <span class="texto-sutil"><%= g.qtd %> atendimento(s) concluído(s)</span>
        </div>
        <form method="POST" action="/painel/comissoes/<%= g.barbeiro.id %>/foto" enctype="multipart/form-data" class="equipe-foto-form">
          <input type="hidden" name="inicio" value="<%= inicioStr %>" />
          <input type="hidden" name="fim" value="<%= fimStr %>" />
          <input type="hidden" name="barbeiro" value="<%= barbeiroSelecionado %>" />
          <label class="equipe-foto" title="Adicionar/trocar foto">
            <% if (g.barbeiro.fotoUrl) { %>
              <img src="<%= g.barbeiro.fotoUrl %>" alt="Foto de <%= g.barbeiro.nome %>" />
            <% } else { %>
              <span class="equipe-foto-inicial"><%= g.barbeiro.nome.charAt(0).toUpperCase() %></span>
            <% } %>
            <span class="equipe-foto-cam" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </span>
            <input type="file" name="foto" accept="image/*" onchange="this.form.submit()" hidden />
          </label>
        </form>
        <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
      </div>

      <div class="equipe-metricas mt-16">
        <div class="equipe-metrica">
          <div class="equipe-metrica-topo">
            <span class="texto-sutil">Ticket médio</span>
            <strong><%= fmtBRL(g.ticketMedio) %></strong>
          </div>
          <div class="barra-prog"><div class="barra-prog-fill" style="width:<%= Math.round((g.ticketMedio / maxTicket) * 100) %>%"></div></div>
        </div>
        <div class="equipe-metrica">
          <div class="equipe-metrica-topo">
            <span class="texto-sutil">Ocupação</span>
            <strong><%= g.ocupacaoPct === null ? '—' : g.ocupacaoPct + '%' %></strong>
          </div>
          <div class="barra-prog"><div class="barra-prog-fill" style="width:<%= g.ocupacaoPct || 0 %>%"></div></div>
        </div>
      </div>

      <!-- Vendas do período: faturamento + comissão + gráfico por dia da semana -->
      <div class="equipe-vendas mt-16">
        <div class="equipe-vendas-topo">
          <span class="texto-sutil">Vendas · período selecionado</span>
        </div>
        <div class="equipe-subcards">
          <div class="equipe-sub">
            <span class="texto-sutil">Faturamento</span>
            <strong><%= fmtBRL(g.faturadoTotal) %></strong>
          </div>
          <div class="equipe-sub">
            <span class="texto-sutil">Comissão</span>
            <strong class="valor-entrada"><%= fmtBRL(g.comissao) %></strong>
          </div>
        </div>
        <div class="semana equipe-semana">
          <% g.barsSemana.forEach(function (d) { %>
            <div class="semana-col">
              <div class="semana-bar" style="height:<%= Math.max(4, Math.round((d.valor / g.maxBarSemana) * 72)) %>px" title="<%= fmtBRL(d.valor) %>"></div>
              <span class="semana-rot"><%= d.rotulo %></span>
            </div>
          <% }) %>
        </div>
      </div>

      <form method="POST" action="/painel/comissoes/percentual/<%= g.barbeiro.id %>" class="form-percentual mt-16">
        <input type="hidden" name="inicio" value="<%= inicioStr %>" />
        <input type="hidden" name="fim" value="<%= fimStr %>" />
        <input type="hidden" name="barbeiro" value="<%= barbeiroSelecionado %>" />
        <label for="perc-<%= g.barbeiro.id %>">Comissão serviços (%)</label>
        <input id="perc-<%= g.barbeiro.id %>" type="number" name="percentual" step="0.5" min="0" max="100"
               value="<%= g.barbeiro.comissaoPercentual %>" />
        <button class="btn btn-secundario btn-sm">Salvar %</button>
        <span class="texto-sutil">Produtos: <%= comissaoProdutoPct %>% (fixo)</span>
      </form>

      <% if (g.atendimentos.length === 0) { %>
        <p class="texto-secundario mt-16">Nenhum atendimento concluído neste período.</p>
      <% } else { %>
        <details class="equipe-detalhes mt-16">
          <summary>Ver atendimentos (<%= g.atendimentos.length %>)</summary>
          <div class="tabela-rolagem">
            <table class="tabela mt-16">
              <thead>
                <tr>
                  <th>Data</th><th>Cliente</th><th>Itens</th>
                  <th class="col-valor">Serviços</th><th class="col-valor">Produtos</th>
                </tr>
              </thead>
              <tbody>
                <% g.atendimentos.forEach(function (a) { %>
                  <tr>
                    <td><%= fmtData(a.ag.data) %></td>
                    <td><%= a.ag.clienteNome %><% if (a.viaPlano) { %> <span class="status">plano</span><% } %></td>
                    <td>
                      <% a.itens.forEach(function (it) { %>
                        <span class="<%= it.ehProduto ? 'item-produto' : '' %>">
                          <%= it.nome %><%= it.quantidade > 1 ? ' ×' + it.quantidade : '' %><%= it.ehProduto ? ' (produto)' : '' %>
                        </span><br />
                      <% }) %>
                    </td>
                    <td class="col-valor"><%= a.servicosSub > 0 ? fmtBRL(a.servicosSub) : '—' %></td>
                    <td class="col-valor"><%= a.produtosSub > 0 ? fmtBRL(a.produtosSub) : '—' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </details>
      <% } %>
    </div>
  </div>
<% }) %>

<script>
  function abrirModalEquipe(id) {
    var o = document.getElementById('equipe-modal-' + id);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  document.querySelectorAll('.equipe-foto-form').forEach(function (f) {
    f.addEventListener('click', function (e) { e.stopPropagation(); });
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
</script>
