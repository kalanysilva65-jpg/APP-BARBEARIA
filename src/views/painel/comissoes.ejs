<!-- Seletor de período: pills (Hoje/Semana/Mês) + ícone de calendário (De/Até + barbeiro) -->
<div class="periodo-barra mb-16">
  <div class="periodo-pills">
    <a class="periodo-pill <%= periodoAtivo === 'hoje' ? 'ativo' : '' %>" href="/painel/comissoes?inicio=<%= presetHoje.inicio %>&fim=<%= presetHoje.fim %>&barbeiro=<%= barbeiroSelecionado %>">Hoje</a>
    <a class="periodo-pill <%= periodoAtivo === 'semana' ? 'ativo' : '' %>" href="/painel/comissoes?inicio=<%= presetSemana.inicio %>&fim=<%= presetSemana.fim %>&barbeiro=<%= barbeiroSelecionado %>">Semana</a>
    <a class="periodo-pill <%= periodoAtivo === 'mes' ? 'ativo' : '' %>" href="/painel/comissoes?inicio=<%= presetMes.inicio %>&fim=<%= presetMes.fim %>&barbeiro=<%= barbeiroSelecionado %>">Mês</a>
  </div>
  <button type="button" class="periodo-cal-btn <%= periodoAtivo === 'custom' ? 'ativo' : '' %>" onclick="abrirModalEquipe('periodo')" title="Escolher período e barbeiro">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
  </button>
</div>

<div class="ag-overlay" id="equipe-modal-periodo" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Período e barbeiro</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <form method="GET" action="/painel/comissoes" class="form mt-16">
      <div class="campo">
        <label for="barbeiro">Barbeiro</label>
        <select id="barbeiro" name="barbeiro">
          <option value="todos" <%= barbeiroSelecionado === 'todos' ? 'selected' : '' %>>Todos os barbeiros</option>
          <% barbeiros.forEach(function (b) { %>
            <option value="<%= b.id %>" <%= barbeiroSelecionado === String(b.id) ? 'selected' : '' %>><%= b.nome %></option>
          <% }) %>
        </select>
      </div>
      <div class="grid-2">
        <div class="campo">
          <label for="inicio">De</label>
          <input id="inicio" type="date" name="inicio" value="<%= inicioStr %>" />
        </div>
        <div class="campo">
          <label for="fim">Até</label>
          <input id="fim" type="date" name="fim" value="<%= fimStr %>" />
        </div>
      </div>
      <div class="modal-acoes">
        <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
        <button class="btn btn-primario">Aplicar</button>
      </div>
    </form>
  </div>
</div>

<!-- Faturado do período -->
<div class="card resumo-caixa mb-16">
  <div class="resumo-titulo">Faturado (serviços + produtos)</div>
  <div class="resumo-valor-grande"><%= fmtBRL(totalServicos + totalProdutos) %></div>
</div>

<!-- Por barbeiro (linha compacta, clicável) -->
<div class="equipe-mini-lista">
  <% grupos.forEach(function (g) { %>
    <div class="equipe-mini" onclick="abrirModalEquipe(<%= g.barbeiro.id %>)">
      <div class="equipe-mini-topo2">
        <span class="equipe-foto equipe-foto--view" style="width:36px;height:36px">
          <% if (g.barbeiro.fotoUrl) { %>
            <img src="<%= g.barbeiro.fotoUrl %>" alt="Foto de <%= g.barbeiro.nome %>" style="width:36px;height:36px" />
          <% } else { %>
            <span class="equipe-foto-inicial" style="font-size:12px"><%= g.barbeiro.nome.charAt(0).toUpperCase() %></span>
          <% } %>
        </span>
        <div class="equipe-mini-info">
          <div class="row-title" style="font-size:14.5px;"><%= g.barbeiro.nome %></div>
          <div class="row-sub">Faturado <%= fmtBRL(g.faturadoTotal) %></div>
        </div>
        <div class="equipe-mini-comissao">
          <div class="row-title" style="font-size:15px;"><%= fmtBRL(g.comissao) %></div>
          <div class="row-sub">comissão <%= g.barbeiro.comissaoPercentual %>%</div>
        </div>
      </div>
      <div class="equipe-mini-stats">
        <div class="equipe-mini-stat">
          <div class="row-title" style="color:rgba(255,255,255,.85);"><%= fmtBRL(g.ticketMedio) %></div>
          <div class="row-sub">Ticket médio</div>
        </div>
        <div class="equipe-mini-stat">
          <div class="row-title" style="color:rgba(255,255,255,.85);"><%= g.ocupacaoPct === null ? '—' : g.ocupacaoPct + '%' %></div>
          <div class="row-sub">Ocupação</div>
        </div>
      </div>
    </div>
  <% }) %>

  <% if (grupos.length === 0) { %>
    <p class="texto-secundario">Nenhum barbeiro para exibir.</p>
  <% } %>
</div>

<!-- Pop-up de detalhe por barbeiro -->
<%
  var rotuloPeriodo = { hoje: 'HOJE', semana: 'SEMANA', mes: 'MÊS', custom: 'PERÍODO' }[periodoAtivo];
%>
<% grupos.forEach(function (g) { %>
  <div class="ag-overlay" id="equipe-modal-<%= g.barbeiro.id %>" onclick="if(event.target===this)fecharModal(this)">
    <div class="ag-modal-box">
      <div class="ag-modal-topo equipe-modal-topo" style="align-items:center;">
        <form method="POST" action="/painel/comissoes/<%= g.barbeiro.id %>/foto" enctype="multipart/form-data" class="equipe-foto-form">
          <input type="hidden" name="inicio" value="<%= inicioStr %>" />
          <input type="hidden" name="fim" value="<%= fimStr %>" />
          <input type="hidden" name="barbeiro" value="<%= barbeiroSelecionado %>" />
          <label class="equipe-foto" style="width:36px;height:36px;" title="Adicionar/trocar foto">
            <% if (g.barbeiro.fotoUrl) { %>
              <img src="<%= g.barbeiro.fotoUrl %>" alt="Foto de <%= g.barbeiro.nome %>" style="width:36px;height:36px;" />
            <% } else { %>
              <span class="equipe-foto-inicial" style="font-size:12px;"><%= g.barbeiro.nome.charAt(0).toUpperCase() %></span>
            <% } %>
            <input type="file" name="foto" accept="image/*" onchange="this.form.submit()" hidden />
          </label>
        </form>
        <div class="equipe-modal-nome">
          <div class="ag-modal-nome"><%= g.barbeiro.nome %></div>
          <span class="row-sub">Faturado <%= fmtBRL(g.faturadoTotal) %> · Comissão <%= fmtBRL(g.comissao) %></span>
        </div>
      </div>

      <span class="dash-rotulo texto-sutil mt-16">FATURAMENTO POR DIA</span>
      <div class="semana equipe-semana">
        <% g.barsSemana.forEach(function (d, i) { %>
          <div class="semana-col">
            <div class="semana-bar <%= i === hojeIdx ? 'hoje' : '' %>" style="height:<%= Math.max(4, Math.round((d.valor / g.maxBarSemana) * 72)) %>px" title="<%= fmtBRL(d.valor) %>"></div>
            <span class="semana-rot <%= i === hojeIdx ? 'hoje' : '' %>"><%= d.rotulo %></span>
          </div>
        <% }) %>
      </div>

      <form method="POST" action="/painel/comissoes/percentual/<%= g.barbeiro.id %>">
        <input type="hidden" name="inicio" value="<%= inicioStr %>" />
        <input type="hidden" name="fim" value="<%= fimStr %>" />
        <input type="hidden" name="barbeiro" value="<%= barbeiroSelecionado %>" />

        <span class="dash-rotulo texto-sutil mt-24">COMISSÃO POR CATEGORIA</span>
        <div class="linha-simples-lista mt-16">
          <div class="linha-simples">
            <span class="linha-simples-titulo">Serviços</span>
            <span class="pill-percent">
              <input type="number" name="percentual" step="0.5" min="0" max="100" value="<%= g.barbeiro.comissaoPercentual %>" />%
            </span>
          </div>
          <div class="linha-simples">
            <span class="linha-simples-titulo">Produtos</span>
            <span class="pill-opcao pill-opcao--estatico"><%= comissaoProdutoPct %>%</span>
          </div>
        </div>

        <span class="dash-rotulo texto-sutil mt-24">ATENDIMENTOS (<%= rotuloPeriodo %>)</span>
        <% if (g.atendimentos.length === 0) { %>
          <p class="texto-secundario mt-16">Nenhum atendimento concluído neste período.</p>
        <% } else { %>
          <div class="linha-simples-lista mt-16">
            <% g.atendimentos.forEach(function (a) { %>
              <div class="linha-simples">
                <span class="linha-simples-info">
                  <span class="linha-simples-titulo"><%= a.ag.clienteNome %></span>
                  <span class="linha-simples-sub"><%= a.itens.map(function (it) { return it.nome; }).join(' + ') %> · <%= a.ag.horaInicio %></span>
                </span>
                <span class="linha-simples-valor"><%= fmtBRL(a.servicosSub + a.produtosSub) %></span>
              </div>
            <% }) %>
          </div>
        <% } %>

        <button class="btn btn-primario btn-bloco mt-24" type="submit">Salvar</button>
      </form>
    </div>
  </div>
<% }) %>

<script>
  function abrirModalEquipe(id) {
    var o = document.getElementById('equipe-modal-' + id);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  document.querySelectorAll('.equipe-foto-form').forEach(function (f) {
    f.addEventListener('click', function (e) { e.stopPropagation(); });
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
</script>
