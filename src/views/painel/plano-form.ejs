<a href="/painel/planos" class="link-voltar">← Voltar</a>

<div class="cabecalho-pagina">
  <h1><%= plano ? 'Editar plano' : 'Novo plano' %></h1>
</div>

<div class="card">
  <form method="POST" class="form" action="<%= plano ? '/painel/planos/' + plano.id : '/painel/planos' %>">
    <div class="campo">
      <label for="nome">Nome</label>
      <input id="nome" name="nome" value="<%= plano ? plano.nome : '' %>" required autofocus />
    </div>

    <div class="campo">
      <label for="tipo">Tipo</label>
      <select id="tipo" name="tipo">
        <option value="limitado" <%= plano && plano.tipo === 'limitado' ? 'selected' : '' %>>Limitado (nº de usos)</option>
        <option value="ilimitado" <%= plano && plano.tipo === 'ilimitado' ? 'selected' : '' %>>Ilimitado (só seg–qui)</option>
      </select>
    </div>

    <div class="campo">
      <label for="servicoId">Serviço incluso</label>
      <select id="servicoId" name="servicoId">
        <option value="">Qualquer serviço</option>
        <% servicos.forEach(function (s) { %>
          <option value="<%= s.id %>" <%= plano && plano.servicoId === s.id ? 'selected' : '' %>><%= s.nome %></option>
        <% }) %>
      </select>
      <span class="texto-sutil">É o serviço que o cliente agenda usando o plano.</span>
    </div>

    <div class="grid-2">
      <div class="campo" id="campo-usos">
        <label for="usos">Nº de usos</label>
        <input id="usos" name="usos" type="number" min="1" value="<%= plano && plano.usos ? plano.usos : '' %>" />
        <span class="texto-sutil">Só vale para o tipo limitado.</span>
      </div>
      <div class="campo">
        <label for="validadeDias">Validade (dias)</label>
        <input id="validadeDias" name="validadeDias" type="number" min="1" value="<%= plano ? plano.validadeDias : 30 %>" />
        <span class="texto-sutil">Ilimitado costuma ser 30 (mensal).</span>
      </div>
    </div>

    <div class="campo">
      <label for="valor">Valor (R$)</label>
      <input id="valor" name="valor" type="number" step="0.01" min="0" value="<%= plano ? (plano.valor / 100).toFixed(2) : '' %>" />
      <span class="texto-sutil">Entra como entrada no caixa quando o cliente adquirir o plano.</span>
    </div>

    <button class="btn btn-primario btn-bloco" type="submit"><%= plano ? 'Salvar' : 'Criar plano' %></button>
  </form>
</div>

<script>
  (function () {
    var tipo = document.getElementById('tipo');
    var campoUsos = document.getElementById('campo-usos');
    function atualizar() {
      campoUsos.style.display = tipo.value === 'ilimitado' ? 'none' : '';
    }
    tipo.addEventListener('change', atualizar);
    atualizar();
  })();
</script>
