<!-- Cards de destaque: faturamento (admin) + agenda de hoje -->
<div class="dash-hero-grid <%= ehAdmin ? '' : 'dash-hero-grid--1' %>">
  <% if (ehAdmin) { %>
    <a href="/painel/caixa" class="dash-azul dash-azul--mini">
      <div class="dash-azul-label">Faturamento hoje</div>
      <div class="dash-azul-num"><span class="n"><%= fmtBRL(ganhoHoje) %></span></div>
      <div class="dash-azul-rodape">
        <span class="dash-azul-prox"><%= concluidosHoje %> atendimento<%= concluidosHoje === 1 ? '' : 's' %></span>
        <span class="dash-azul-cliente">
          <% if (variacaoHojeOntem === null) { %>
            — vs ontem
          <% } else { %>
            <%= variacaoHojeOntem >= 0 ? '+' : '' %><%= variacaoHojeOntem %>% vs ontem
          <% } %>
        </span>
      </div>
    </a>
  <% } %>
  <a href="/painel/agenda" class="dash-azul dash-azul--mini">
    <div class="dash-azul-label">Agenda de hoje</div>
    <div class="dash-azul-num"><span class="n"><%= totalHoje %></span></div>
    <div class="dash-azul-rodape">
      <span class="dash-azul-prox"><%= concluidosHoje %> concluído<%= concluidosHoje === 1 ? '' : 's' %></span>
      <span class="dash-azul-cliente"><%= restantesHoje %> restante<%= restantesHoje === 1 ? '' : 's' %></span>
    </div>
  </a>
</div>

<!-- Semana atual (faturamento, admin) -->
<% if (ehAdmin) { %>
  <a href="/painel/caixa" class="card mb-16">
    <span class="dash-rotulo texto-sutil">SEMANA ATUAL</span>
    <div class="semana mt-16">
      <% barras.forEach(function (d) { %>
        <div class="semana-col">
          <div class="semana-bar <%= d.hoje ? 'hoje' : '' %>" style="height:<%= Math.max(4, Math.round((d.valor / maxBarra) * 72)) %>px" title="<%= fmtBRL(d.valor) %>"></div>
          <span class="semana-rot <%= d.hoje ? 'hoje' : '' %>"><%= d.rotulo %></span>
          <% if (d.hoje) { %><span class="semana-rot-dot" style="background:#fff"></span><% } %>
        </div>
      <% }) %>
    </div>
  </a>
<% } %>

<!-- Métricas -->
<div class="card mb-16">
  <span class="dash-rotulo texto-sutil">MÉTRICAS</span>
  <div class="dash-hero-grid" style="margin:12px 0 0;">
    <div class="dash-metrica-topo">
      <strong><%= produtividade %>%</strong>
      <span>Ocupação</span>
    </div>
    <div class="dash-metrica-topo">
      <strong><%= retencao %>%</strong>
      <span>Retenção</span>
    </div>
  </div>
</div>

<!-- Próximos atendimentos -->
<div class="card mb-16">
  <div class="flex-fim" style="justify-content:space-between;">
    <span class="dash-rotulo texto-sutil">PRÓXIMOS</span>
    <a href="/painel/agenda" class="texto-secundario" style="font-size:12px;">Ver agenda</a>
  </div>
  <% if (proximosLista.length === 0) { %>
    <p class="texto-secundario mt-16">Sem próximos atendimentos hoje.</p>
  <% } else { %>
    <div class="dash-proximos-lista mt-16">
      <% proximosLista.forEach(function (p) { %>
        <div class="dash-proximo-item">
          <span class="dash-proximo-hora"><%= p.hora %></span>
          <div class="dash-proximo-info">
            <span class="dash-proximo-nome"><%= p.nome %></span>
            <span class="texto-sutil"><%= p.servico %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Novos clientes -->
<a href="/painel/clientes" class="card dash-card-linha">
  <div>
    <span class="dash-rotulo texto-sutil">NOVOS CLIENTES</span>
    <div class="texto-sutil mt-16">Últimos 90 dias</div>
  </div>
  <div class="dash-novos"><%= novosClientes %></div>
</a>
