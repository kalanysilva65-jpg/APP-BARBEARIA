<% if (ehAdmin && estoqueBaixo && estoqueBaixo.length > 0) { %>
  <div class="alerta alerta-aviso">
    <strong>Estoque baixo:</strong>
    <%= estoqueBaixo.map(function (i) { return i.nome + ' (' + i.quantidade + ')'; }).join(', ') %>.
  </div>
<% } %>

<!-- Cards de destaque: faturamento (admin) + agenda de hoje -->
<div class="dash-hero-grid <%= ehAdmin ? '' : 'dash-hero-grid--1' %>">
  <% if (ehAdmin) { %>
    <a href="/painel/caixa" class="dash-azul dash-azul--mini">
      <div class="dash-azul-label">Faturamento hoje</div>
      <div class="dash-azul-num"><span class="n"><%= fmtBRL(ganhoHoje) %></span></div>
      <div class="dash-azul-rodape">
        <span class="dash-azul-prox"><%= concluidosHoje %> atendimento<%= concluidosHoje === 1 ? '' : 's' %></span>
        <span class="dash-azul-cliente">
          <% if (variacaoHojeOntem === null) { %>
            — vs ontem
          <% } else { %>
            <%= variacaoHojeOntem >= 0 ? '+' : '' %><%= variacaoHojeOntem %>% vs ontem
          <% } %>
        </span>
      </div>
    </a>
  <% } %>
  <a href="/painel/agenda" class="dash-azul dash-azul--mini">
    <div class="dash-azul-label">Agenda de hoje</div>
    <div class="dash-azul-num"><span class="n"><%= totalHoje %></span></div>
    <div class="dash-azul-rodape">
      <span class="dash-azul-prox"><%= concluidosHoje %> concluído<%= concluidosHoje === 1 ? '' : 's' %></span>
      <span class="dash-azul-cliente"><%= restantesHoje %> restante<%= restantesHoje === 1 ? '' : 's' %></span>
    </div>
  </a>
</div>

<!-- Produtividade + Retenção -->
<div class="dash-grid">
  <div class="dash-card">
    <div class="dash-card-titulo">Produtividade</div>
    <div class="dash-card-sub">Ocupação · 90 dias</div>
    <div class="dash-card-num"><%= produtividade %>%</div>
    <div class="barra-prog"><div class="barra-prog-fill" style="width:<%= produtividade %>%"></div></div>
  </div>
  <div class="dash-card">
    <div class="dash-card-titulo">Retenção</div>
    <div class="dash-card-sub">Voltaram · 90 dias</div>
    <div class="dash-card-num"><%= retencao %>%</div>
    <div class="barra-prog"><div class="barra-prog-fill" style="width:<%= retencao %>%"></div></div>
  </div>
</div>

<!-- Novos clientes -->
<a href="/painel/clientes" class="dash-card dash-card-linha">
  <div>
    <div class="dash-card-titulo">Novos clientes</div>
    <div class="dash-card-sub">Últimos 90 dias</div>
  </div>
  <div class="dash-novos"><%= novosClientes %></div>
</a>

<!-- Faturamento da semana (admin) -->
<% if (ehAdmin) { %>
  <a href="/painel/caixa" class="dash-card dash-fat">
    <div class="dash-fat-topo">
      <div>
        <div class="dash-card-titulo">Faturamento da semana</div>
        <div class="dash-card-sub">Previsto hoje <%= fmtBRL(previstoHoje) %></div>
      </div>
    </div>
    <div class="semana">
      <% barras.forEach(function (d) { %>
        <div class="semana-col">
          <div class="semana-bar <%= d.hoje ? 'hoje' : '' %>" style="height:<%= Math.max(4, Math.round((d.valor / maxBarra) * 72)) %>px" title="<%= fmtBRL(d.valor) %>"></div>
          <span class="semana-rot <%= d.hoje ? 'hoje' : '' %>"><%= d.rotulo %></span>
        </div>
      <% }) %>
    </div>
  </a>
<% } %>
