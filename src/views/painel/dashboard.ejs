<%
  var barbeariaNome = (typeof barbeariaAtual !== 'undefined' && barbeariaAtual) ? barbeariaAtual.nome : 'Barbearia';
  var capaUrl = (typeof barbeariaAtual !== 'undefined' && barbeariaAtual) ? barbeariaAtual.capaUrl : null;
  var papelLabel = ehAdmin ? 'Gestor' : 'Barbeiro';
%>

<!-- Hero com foto de capa + saudação -->
<div class="home-hero">
  <% if (capaUrl) { %>
    <img class="home-hero-img" src="<%= capaUrl %>" alt="Capa de <%= barbeariaNome %>" />
  <% } %>
  <div class="home-hero-sombra"></div>

  <%/* Sem avatar aqui: o hero é só a foto de capa + a saudação. A troca da foto
       de perfil segue no cabeçalho das demais telas do painel. */%>
  <div class="home-hero-texto">
    <span class="home-hero-badge"><%= saudacao %> · <%= hojeFormatado %></span>
    <div class="home-hero-nome"><%= usuario.nome %></div>
    <div class="home-hero-sub"><%= papelLabel %> · <%= barbeariaNome %></div>
  </div>
</div>

<div class="home-corpo">
  <div class="home-bento">
    <% if (ehAdmin) { %>
      <!-- Faturamento (card escuro, ocupa 2 linhas) -->
      <a href="/painel/caixa" class="home-card home-card--fat">
        <div class="home-card-eyebrow">
          Hoje<% if (variacaoHojeOntem !== null) { %> · <%= variacaoHojeOntem >= 0 ? '+' : '' %><%= variacaoHojeOntem %>%<% } %>
        </div>
        <svg class="home-fat-spark" viewBox="0 0 140 30" preserveAspectRatio="none" aria-hidden="true">
          <path d="<%= sparkPath %>" fill="none" stroke="rgba(255,255,255,0.6)" stroke-width="2" stroke-linecap="round" />
        </svg>
        <div>
          <div class="home-fat-num"><%= fmtBRL(ganhoHoje) %></div>
          <div class="home-fat-legenda">Faturamento hoje</div>
        </div>
      </a>

      <!-- Ocupação (card branco) -->
      <a href="/painel/comissoes" class="home-card home-card--branco">
        <div class="home-card-topo">
          <span class="home-card-label">Ocupação</span>
          <span class="home-card-icone"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg></span>
        </div>
        <div class="home-card-num"><%= produtividade %>%</div>
        <div class="home-bar"><div style="width:<%= Math.min(100, produtividade) %>%"></div></div>
      </a>

      <!-- Cortes hoje + Ticket médio (card branco empilhado) -->
      <div class="home-card home-card--stack">
        <a href="/painel/agenda" class="home-stack-item" style="display:block;text-decoration:none;color:inherit;">
          <div class="home-card-topo">
            <span class="home-card-label">Cortes hoje</span>
            <span class="home-card-icone"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17 17 7M9 7h8v8"/></svg></span>
          </div>
          <div class="home-card-num"><%= concluidosHoje %></div>
        </a>
        <div class="home-stack-item">
          <div class="home-card-topo">
            <span class="home-card-label">Ticket médio</span>
          </div>
          <div class="home-card-num"><%= fmtBRL(ticketMedioHoje) %></div>
        </div>
      </div>
    <% } else { %>
      <!-- Funcionário: sem faturamento. Cortes hoje ocupa o card grande. -->
      <a href="/painel/agenda" class="home-card home-card--fat">
        <div class="home-card-eyebrow">Hoje</div>
        <div>
          <div class="home-fat-num"><%= totalHoje %></div>
          <div class="home-fat-legenda">Agendamentos hoje</div>
        </div>
      </a>
      <div class="home-card home-card--branco">
        <div class="home-card-topo"><span class="home-card-label">Concluídos</span></div>
        <div class="home-card-num"><%= concluidosHoje %></div>
      </div>
      <div class="home-card home-card--branco">
        <div class="home-card-topo"><span class="home-card-label">Restantes</span></div>
        <div class="home-card-num"><%= restantesHoje %></div>
      </div>
    <% } %>
  </div>

  <!-- Próximos cortes -->
  <div class="home-secao-titulo">Próximos cortes</div>
  <% if (proximosLista.length === 0) { %>
    <div class="home-proximos"><div class="home-vazio">Sem próximos atendimentos hoje.</div></div>
  <% } else { %>
    <div class="home-proximos">
      <% proximosLista.forEach(function (p) { %>
        <a href="/painel/agenda" class="home-prox-item">
          <span class="home-prox-hora"><%= p.hora %></span>
          <span class="home-prox-info">
            <span class="home-prox-cliente"><%= p.nome %></span>
            <span class="home-prox-servico"><%= p.servico %></span>
          </span>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>
