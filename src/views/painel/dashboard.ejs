<div class="cabecalho-pagina">
  <h1>Olá, <%= usuario.nome %></h1>
  <p class="texto-secundario">Bem-vindo ao painel da barbearia.</p>
</div>

<% if (ehAdmin && estoqueBaixo && estoqueBaixo.length > 0) { %>
  <div class="alerta alerta-aviso">
    <strong>Estoque baixo:</strong>
    <%= estoqueBaixo.map(function (i) { return i.nome + ' (' + i.quantidade + ')'; }).join(', ') %>.
  </div>
<% } %>

<div class="grade-cards">
  <a href="/painel/agenda" class="card card-link">
    <h2 class="card-titulo">Agenda</h2>
    <p class="texto-secundario">
      <%= ehAdmin ? 'Veja a agenda de todos os barbeiros.' : 'Veja e gerencie a sua agenda.' %>
    </p>
  </a>

  <a href="/painel/clientes" class="card card-link">
    <h2 class="card-titulo">Clientes</h2>
    <p class="texto-secundario">Cadastro de clientes com telefone único.</p>
  </a>

  <a href="/painel/planos" class="card card-link">
    <h2 class="card-titulo">Planos</h2>
    <p class="texto-secundario">Planos limitados e ilimitados da barbearia.</p>
  </a>

  <% if (ehAdmin) { %>
    <a href="/painel/servicos" class="card card-link">
      <h2 class="card-titulo">Serviços & Produtos</h2>
      <p class="texto-secundario">Cadastre cortes, produtos e categorias.</p>
    </a>
    <a href="/painel/estoque" class="card card-link">
      <h2 class="card-titulo">Estoque</h2>
      <p class="texto-secundario">Controle insumos e alertas de reposição.</p>
    </a>
    <a href="/painel/caixa" class="card card-link">
      <h2 class="card-titulo">Caixa</h2>
      <p class="texto-secundario">Entradas, saídas e saldo do dia e do mês.</p>
    </a>
    <a href="/painel/comissoes" class="card card-link">
      <h2 class="card-titulo">Comissões</h2>
      <p class="texto-secundario">50% por barbeiro sobre serviços concluídos.</p>
    </a>
    <a href="/painel/horarios" class="card card-link">
      <h2 class="card-titulo">Horários</h2>
      <p class="texto-secundario">Jornadas e bloqueios de cada barbeiro.</p>
    </a>
  <% } %>
</div>
