<div class="cabecalho-pagina agenda-cabecalho">
  <div>
    <h1>Caixa</h1>
    <p class="texto-secundario">Entradas, saídas e saldo do período selecionado.</p>
  </div>
  <form method="POST" action="/painel/caixa/config" class="caixa-auto">
    <input type="hidden" name="ligado" value="<%= autoLigado ? 'false' : 'true' %>" />
    <span class="caixa-auto-label">Entrada automática</span>
    <button class="btn <%= autoLigado ? 'btn-secundario' : 'btn-primario' %> btn-sm btn-pill">
      <%= autoLigado ? 'Desligar' : 'Ligar' %>
    </button>
  </form>
</div>

<!-- Seletor de período (data a data) -->
<div class="card mb-16">
  <div class="comissao-presets">
    <a class="btn btn-secundario btn-sm" href="/painel/caixa?inicio=<%= presetHoje.inicio %>&fim=<%= presetHoje.fim %>">Hoje</a>
    <a class="btn btn-secundario btn-sm" href="/painel/caixa?inicio=<%= presetSemana.inicio %>&fim=<%= presetSemana.fim %>">Semana</a>
    <a class="btn btn-secundario btn-sm" href="/painel/caixa?inicio=<%= presetMes.inicio %>&fim=<%= presetMes.fim %>">Mês</a>
  </div>
  <form method="GET" action="/painel/caixa" class="form-periodo mt-16">
    <div class="campo">
      <label for="inicio">De</label>
      <input id="inicio" type="date" name="inicio" value="<%= inicioStr %>" />
    </div>
    <div class="campo">
      <label for="fim">Até</label>
      <input id="fim" type="date" name="fim" value="<%= fimStr %>" />
    </div>
    <button class="btn btn-primario btn-sm">Aplicar</button>
  </form>
</div>

<!-- Ganhos do período + resumo -->
<div class="caixa-topo">
  <div class="card caixa-ganhos">
    <div class="caixa-ganhos-topo">
      <span class="texto-sutil">Ganhos · <%= nomePeriodoSel %></span>
      <div class="caixa-ganhos-valor"><%= fmtBRL(resumoPeriodo.entrou) %></div>
    </div>
    <div class="semana caixa-semana">
      <% barrasPeriodo.forEach(function (d) { %>
        <div class="semana-col">
          <div class="semana-bar <%= d.hoje ? 'hoje' : '' %>" style="height:<%= Math.max(4, Math.round((d.valor / maxBarraPeriodo) * 72)) %>px" title="<%= fmtBRL(d.valor) %>"></div>
          <span class="semana-rot <%= d.hoje ? 'hoje' : '' %>"><%= d.rotulo %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="card caixa-resumo-hoje">
    <div class="resumo-titulo"><%= nomePeriodoSel %></div>
    <div class="resumo-linha"><span class="texto-sutil">Entrou</span><span class="valor-entrada">+<%= fmtBRL(resumoPeriodo.entrou) %></span></div>
    <div class="resumo-linha"><span class="texto-sutil">Saiu</span><span class="valor-saida">−<%= fmtBRL(resumoPeriodo.saiu) %></span></div>
    <div class="resumo-linha total"><span>Saldo</span><span><%= fmtBRL(resumoPeriodo.saldo) %></span></div>
    <% if (incluiHoje) { %>
      <div class="resumo-linha mt-8"><span class="texto-sutil">Saldo de hoje</span><span><%= fmtBRL(resumoHoje.saldo) %></span></div>
    <% } %>
  </div>
</div>

<!-- Ações: abrem em pop-up -->
<div class="caixa-acoes">
  <button type="button" class="btn btn-secundario btn-pill" onclick="abrirModalCaixa('categorias')">Categorias de caixa</button>
  <button type="button" class="btn btn-primario btn-pill" onclick="abrirModalCaixa('lancamento')">+ Novo lançamento</button>
</div>

<!-- Movimentações do período -->
<div class="card mt-16">
  <h2>Movimentações · <%= nomePeriodoSel %></h2>

  <% if (lancamentos.length === 0) { %>
    <p class="texto-secundario mt-16">Nenhum lançamento neste período.</p>
  <% } else { %>
    <div class="tabela-rolagem">
      <table class="tabela mt-16">
        <thead>
          <tr><th>Data</th><th>Descrição</th><th>Categoria</th><th class="col-valor">Valor</th><th></th></tr>
        </thead>
        <tbody>
          <% lancamentos.forEach(function (l) { %>
            <tr>
              <td><%= fmtData(l.data) %></td>
              <td><%= l.descricao %><% if (l.agendamentoId) { %> <span class="texto-sutil">(auto)</span><% } %></td>
              <td><%= l.categoria ? l.categoria.nome : '—' %></td>
              <td class="col-valor <%= l.tipo === 'entrada' ? 'valor-entrada' : 'valor-saida' %>">
                <%= l.tipo === 'entrada' ? '+' : '−' %><%= fmtBRL(l.valor) %>
              </td>
              <td class="col-acao">
                <form method="POST" action="/painel/caixa/<%= l.id %>/remover" class="inline"
                      onsubmit="return confirm('Excluir este lançamento?')">
                  <input type="hidden" name="inicio" value="<%= inicioStr %>" />
                  <input type="hidden" name="fim" value="<%= fimStr %>" />
                  <button class="btn-x" title="Excluir">×</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Pop-up: Novo lançamento -->
<div class="ag-overlay" id="caixa-modal-lancamento" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Novo lançamento</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <% if (categorias.length === 0) { %>
      <p class="texto-secundario mt-16">Cadastre uma categoria para poder lançar.</p>
    <% } else { %>
      <form method="POST" action="/painel/caixa" class="form mt-16">
        <input type="hidden" name="inicio" value="<%= inicioStr %>" />
        <input type="hidden" name="fim" value="<%= fimStr %>" />
        <div class="campo">
          <label for="categoriaId">Categoria</label>
          <select id="categoriaId" name="categoriaId" required>
            <option value="">Selecione…</option>
            <% categorias.forEach(function (c) { %>
              <option value="<%= c.id %>"><%= c.tipo === 'entrada' ? 'Entrada' : 'Saída' %> · <%= c.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="grid-2">
          <div class="campo">
            <label for="valor">Valor (R$)</label>
            <input id="valor" name="valor" type="number" step="0.01" min="0" required />
          </div>
          <div class="campo">
            <label for="data">Data</label>
            <input id="data" name="data" type="date" value="<%= hojeIso %>" />
          </div>
        </div>
        <div class="campo">
          <label for="descricao">Descrição (opcional)</label>
          <input id="descricao" name="descricao" placeholder="Ex.: Corte do João" />
        </div>
        <button class="btn btn-primario btn-bloco" type="submit">Registrar lançamento</button>
      </form>
    <% } %>
  </div>
</div>

<!-- Pop-up: Categorias de caixa -->
<div class="ag-overlay" id="caixa-modal-categorias" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Categorias de caixa</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <p class="texto-secundario">Cada categoria é de entrada ou saída. Remover não apaga lançamentos.</p>

    <form method="POST" action="/painel/caixa/categorias" class="form-cat-caixa mt-16">
      <input name="nome" placeholder="Nova categoria" required />
      <select name="tipo">
        <option value="entrada">Entrada</option>
        <option value="saida">Saída</option>
      </select>
      <button class="btn btn-secundario btn-sm">Adicionar</button>
    </form>

    <ul class="lista-categorias mt-16">
      <% categorias.forEach(function (c) { %>
        <li>
          <form method="POST" action="/painel/caixa/categorias/<%= c.id %>" class="form-cat-caixa">
            <input name="nome" value="<%= c.nome %>" />
            <select name="tipo">
              <option value="entrada" <%= c.tipo === 'entrada' ? 'selected' : '' %>>Entrada</option>
              <option value="saida" <%= c.tipo === 'saida' ? 'selected' : '' %>>Saída</option>
            </select>
            <span class="texto-sutil"><%= c._count.lancamentos %></span>
            <button class="btn btn-secundario btn-sm">Salvar</button>
          </form>
          <form method="POST" action="/painel/caixa/categorias/<%= c.id %>/remover" class="inline"
                onsubmit="return confirm('Remover esta categoria?')">
            <button class="btn-x" title="Remover categoria">×</button>
          </form>
        </li>
      <% }) %>
      <% if (categorias.length === 0) { %>
        <li class="texto-secundario">Nenhuma categoria.</li>
      <% } %>
    </ul>
  </div>
</div>

<script>
  function abrirModalCaixa(nome) {
    var o = document.getElementById('caixa-modal-' + nome);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
</script>
