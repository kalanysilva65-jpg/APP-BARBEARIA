<div class="cabecalho-pagina agenda-cabecalho">
  <div>
    <h1>Caixa</h1>
    <p class="texto-secundario">Entradas, saídas e saldo do período selecionado.</p>
  </div>
  <form method="POST" action="/painel/caixa/config" class="caixa-auto">
    <input type="hidden" name="ligado" value="<%= autoLigado ? 'false' : 'true' %>" />
    <span class="caixa-auto-label">Entrada automática</span>
    <button class="btn <%= autoLigado ? 'btn-secundario' : 'btn-primario' %> btn-sm btn-pill">
      <%= autoLigado ? 'Desligar' : 'Ligar' %>
    </button>
  </form>
</div>

<!-- Seletor de período: pills (Hoje/Semana/Mês) + ícone de calendário (De/Até) -->
<div class="periodo-barra mb-16">
  <div class="periodo-pills">
    <a class="periodo-pill <%= periodoAtivo === 'hoje' ? 'ativo' : '' %>" href="/painel/caixa?inicio=<%= presetHoje.inicio %>&fim=<%= presetHoje.fim %>">Hoje</a>
    <a class="periodo-pill <%= periodoAtivo === 'semana' ? 'ativo' : '' %>" href="/painel/caixa?inicio=<%= presetSemana.inicio %>&fim=<%= presetSemana.fim %>">Semana</a>
    <a class="periodo-pill <%= periodoAtivo === 'mes' ? 'ativo' : '' %>" href="/painel/caixa?inicio=<%= presetMes.inicio %>&fim=<%= presetMes.fim %>">Mês</a>
  </div>
  <button type="button" class="periodo-cal-btn <%= periodoAtivo === 'custom' ? 'ativo' : '' %>" onclick="abrirModalCaixa('periodo')" title="Escolher período (De/Até)">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
  </button>
</div>

<!-- Gráfico do período -->
<div class="card caixa-ganhos mb-16">
  <span class="caixa-ganhos-rotulo texto-sutil"><%= nomePeriodoSel.toUpperCase() %></span>
  <div class="semana caixa-semana">
    <% barrasPeriodo.forEach(function (d) { %>
      <div class="semana-col">
        <div class="semana-bar <%= d.hoje ? 'hoje' : '' %>" style="height:<%= Math.max(4, Math.round((d.valor / maxBarraPeriodo) * 72)) %>px" title="<%= fmtBRL(d.valor) %>"></div>
        <span class="semana-rot <%= d.hoje ? 'hoje' : '' %>"><%= d.rotulo %></span>
      </div>
    <% }) %>
  </div>
</div>

<!-- Entrou / Saiu / Lucro do período -->
<div class="card caixa-resumo-hoje mb-16">
  <div class="resumo-linha"><span class="texto-sutil">Entrou</span><span class="valor-entrada">+<%= fmtBRL(resumoPeriodo.entrou) %></span></div>
  <div class="resumo-linha"><span class="texto-sutil">Saiu</span><span class="valor-saida">−<%= fmtBRL(resumoPeriodo.saiu) %></span></div>
  <div class="resumo-linha total"><span>Lucro</span><span><%= fmtBRL(resumoPeriodo.saldo) %></span></div>
</div>

<!-- Saldo do dia + saldo do mês (fixos, não mudam com o período acima) -->
<div class="caixa-saldos mb-16">
  <div class="caixa-saldo caixa-saldo--destaque">
    <span class="caixa-saldo-label">Saldo do dia</span>
    <span class="caixa-saldo-valor"><%= fmtBRL(resumoHoje.saldo) %></span>
  </div>
  <div class="caixa-saldo">
    <span class="caixa-saldo-label">Saldo do mês</span>
    <span class="caixa-saldo-valor"><%= fmtBRL(resumoMesAtual.saldo) %></span>
  </div>
</div>

<!-- Movimentações do período -->
<div class="card mt-16">
  <h2>Movimentações · <%= nomePeriodoSel %></h2>

  <% if (lancamentos.length === 0) { %>
    <p class="texto-secundario mt-16">Nenhum lançamento neste período.</p>
  <% } else { %>
    <div class="caixa-mov-lista mt-16">
      <% lancamentos.forEach(function (l) { %>
        <div class="caixa-mov-item">
          <div class="caixa-mov-info">
            <span class="caixa-mov-titulo"><%= l.descricao %><% if (l.agendamentoId) { %> <span class="texto-sutil">(auto)</span><% } %></span>
            <span class="caixa-mov-sub"><%= l.categoria ? l.categoria.nome : '—' %> · <%= fmtData(l.data) %></span>
          </div>
          <span class="caixa-mov-valor <%= l.tipo === 'entrada' ? 'valor-entrada' : 'valor-saida' %>">
            <%= l.tipo === 'entrada' ? '+' : '−' %><%= fmtBRL(l.valor) %>
          </span>
          <form method="POST" action="/painel/caixa/<%= l.id %>/remover" class="caixa-mov-x"
                onsubmit="return confirm('Excluir este lançamento?')">
            <input type="hidden" name="inicio" value="<%= inicioStr %>" />
            <input type="hidden" name="fim" value="<%= fimStr %>" />
            <button title="Excluir">×</button>
          </form>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<!-- Botão flutuante: Novo lançamento / Categorias (só nesta tela) -->
<div class="agenda-fab-wrap">
  <div class="agenda-fab-menu" id="caixa-fab-menu">
    <button type="button" class="agenda-fab-opcao" onclick="abrirModalCaixa('lancamento')">
      <span>Novo lançamento</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>
    <button type="button" class="agenda-fab-opcao" onclick="abrirModalCaixa('categorias')">
      <span>Categorias de caixa</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
    </button>
  </div>
  <button type="button" class="agenda-fab" onclick="document.getElementById('caixa-fab-menu').classList.toggle('aberto')" aria-label="Nova ação">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
</div>

<!-- Pop-up: escolher período (De/Até) -->
<div class="ag-overlay" id="caixa-modal-periodo" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Escolher período</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <form method="GET" action="/painel/caixa" class="form mt-16">
      <div class="grid-2">
        <div class="campo">
          <label for="inicio">De</label>
          <input id="inicio" type="date" name="inicio" value="<%= inicioStr %>" />
        </div>
        <div class="campo">
          <label for="fim">Até</label>
          <input id="fim" type="date" name="fim" value="<%= fimStr %>" />
        </div>
      </div>
      <button class="btn btn-primario btn-bloco">Aplicar</button>
    </form>
  </div>
</div>

<!-- Pop-up: Novo lançamento -->
<div class="ag-overlay" id="caixa-modal-lancamento" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Novo lançamento</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <% if (categorias.length === 0) { %>
      <p class="texto-secundario mt-16">Cadastre uma categoria para poder lançar.</p>
    <% } else { %>
      <form method="POST" action="/painel/caixa" class="form mt-16">
        <input type="hidden" name="inicio" value="<%= inicioStr %>" />
        <input type="hidden" name="fim" value="<%= fimStr %>" />
        <div class="campo">
          <label for="categoriaId">Categoria</label>
          <select id="categoriaId" name="categoriaId" required>
            <option value="">Selecione…</option>
            <% categorias.forEach(function (c) { %>
              <option value="<%= c.id %>"><%= c.tipo === 'entrada' ? 'Entrada' : 'Saída' %> · <%= c.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="grid-2">
          <div class="campo">
            <label for="valor">Valor (R$)</label>
            <input id="valor" name="valor" type="number" step="0.01" min="0" required />
          </div>
          <div class="campo">
            <label for="data">Data</label>
            <input id="data" name="data" type="date" value="<%= hojeIso %>" />
          </div>
        </div>
        <div class="campo">
          <label for="descricao">Descrição (opcional)</label>
          <input id="descricao" name="descricao" placeholder="Ex.: Corte do João" />
        </div>
        <button class="btn btn-primario btn-bloco" type="submit">Registrar lançamento</button>
      </form>
    <% } %>
  </div>
</div>

<!-- Pop-up: Categorias de caixa -->
<div class="ag-overlay" id="caixa-modal-categorias" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Categorias de caixa</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <p class="texto-secundario">Cada categoria é de entrada ou saída. Remover não apaga lançamentos.</p>

    <form method="POST" action="/painel/caixa/categorias" class="form-cat-caixa mt-16">
      <input name="nome" placeholder="Nova categoria" required />
      <select name="tipo">
        <option value="entrada">Entrada</option>
        <option value="saida">Saída</option>
      </select>
      <button class="btn btn-secundario btn-sm">Adicionar</button>
    </form>

    <ul class="lista-categorias mt-16">
      <% categorias.forEach(function (c) { %>
        <li>
          <form method="POST" action="/painel/caixa/categorias/<%= c.id %>" class="form-cat-caixa">
            <input name="nome" value="<%= c.nome %>" />
            <select name="tipo">
              <option value="entrada" <%= c.tipo === 'entrada' ? 'selected' : '' %>>Entrada</option>
              <option value="saida" <%= c.tipo === 'saida' ? 'selected' : '' %>>Saída</option>
            </select>
            <span class="texto-sutil"><%= c._count.lancamentos %></span>
            <button class="btn btn-secundario btn-sm">Salvar</button>
          </form>
          <form method="POST" action="/painel/caixa/categorias/<%= c.id %>/remover" class="inline"
                onsubmit="return confirm('Remover esta categoria?')">
            <button class="btn-x" title="Remover categoria">×</button>
          </form>
        </li>
      <% }) %>
      <% if (categorias.length === 0) { %>
        <li class="texto-secundario">Nenhuma categoria.</li>
      <% } %>
    </ul>
  </div>
</div>

<script>
  function abrirModalCaixa(nome) {
    var menu = document.getElementById('caixa-fab-menu');
    if (menu) menu.classList.remove('aberto');
    var o = document.getElementById('caixa-modal-' + nome);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  document.addEventListener('click', function (e) {
    var wrap = document.querySelector('.agenda-fab-wrap');
    if (wrap && !wrap.contains(e.target)) {
      var menu = document.getElementById('caixa-fab-menu');
      if (menu) menu.classList.remove('aberto');
    }
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
</script>
