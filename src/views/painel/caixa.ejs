<div class="cabecalho-pagina">
  <h1>Caixa</h1>
  <p class="texto-secundario">Entradas, saídas e saldo do dia e do mês.</p>
</div>

<!-- Toggle de entrada automática -->
<div class="card flex-entre" style="flex-wrap: wrap; gap: 12px">
  <div>
    <strong>Entrada automática</strong>
    <div class="texto-sutil">Ao concluir um agendamento, lança o valor como entrada no caixa.</div>
  </div>
  <div class="flex" style="align-items: center; gap: 10px">
    <span class="status <%= autoLigado ? 'status-concluido' : '' %>"><%= autoLigado ? 'Ligada' : 'Desligada' %></span>
    <form method="POST" action="/painel/caixa/config" class="inline">
      <input type="hidden" name="ligado" value="<%= autoLigado ? 'false' : 'true' %>" />
      <button class="btn <%= autoLigado ? 'btn-secundario' : 'btn-primario' %> btn-sm">
        <%= autoLigado ? 'Desligar' : 'Ligar' %>
      </button>
    </form>
  </div>
</div>

<!-- Resumos -->
<div class="grade-resumo mt-16">
  <div class="card resumo-caixa">
    <div class="resumo-titulo">Hoje</div>
    <div class="resumo-linha"><span class="texto-sutil">Entrou</span><span class="valor-entrada">+<%= fmtBRL(resumoHoje.entrou) %></span></div>
    <div class="resumo-linha"><span class="texto-sutil">Saiu</span><span class="valor-saida">−<%= fmtBRL(resumoHoje.saiu) %></span></div>
    <div class="resumo-linha total"><span>Saldo</span><span><%= fmtBRL(resumoHoje.saldo) %></span></div>
  </div>
  <div class="card resumo-caixa">
    <div class="resumo-titulo">Mês</div>
    <div class="resumo-linha"><span class="texto-sutil">Entrou</span><span class="valor-entrada">+<%= fmtBRL(resumoMes.entrou) %></span></div>
    <div class="resumo-linha"><span class="texto-sutil">Saiu</span><span class="valor-saida">−<%= fmtBRL(resumoMes.saiu) %></span></div>
    <div class="resumo-linha total"><span>Saldo</span><span><%= fmtBRL(resumoMes.saldo) %></span></div>
  </div>
</div>

<!-- Novo lançamento -->
<div class="card mt-16">
  <h2>Novo lançamento</h2>
  <% if (categorias.length === 0) { %>
    <p class="texto-secundario mt-16">Cadastre uma categoria abaixo para poder lançar.</p>
  <% } else { %>
    <form method="POST" action="/painel/caixa" class="form mt-16">
      <div class="campo">
        <label for="categoriaId">Categoria</label>
        <select id="categoriaId" name="categoriaId" required>
          <option value="">Selecione…</option>
          <% categorias.forEach(function (c) { %>
            <option value="<%= c.id %>"><%= c.tipo === 'entrada' ? 'Entrada' : 'Saída' %> · <%= c.nome %></option>
          <% }) %>
        </select>
      </div>
      <div class="grid-2">
        <div class="campo">
          <label for="valor">Valor (R$)</label>
          <input id="valor" name="valor" type="number" step="0.01" min="0" required />
        </div>
        <div class="campo">
          <label for="data">Data</label>
          <input id="data" name="data" type="date" value="<%= hojeIso %>" />
        </div>
      </div>
      <div class="campo">
        <label for="descricao">Descrição (opcional)</label>
        <input id="descricao" name="descricao" placeholder="Ex.: Corte do João" />
      </div>
      <button class="btn btn-primario btn-bloco" type="submit">Registrar lançamento</button>
    </form>
  <% } %>
</div>

<!-- Movimentações do mês -->
<div class="card mt-16">
  <div class="flex-entre" style="flex-wrap: wrap; gap: 8px">
    <h2>Movimentações</h2>
    <form method="GET" action="/painel/caixa" class="agenda-filtros">
      <a class="btn btn-secundario btn-sm" href="/painel/caixa?mes=<%= mesAnterior %>" title="Mês anterior">←</a>
      <input type="month" name="mes" value="<%= mesSel %>" onchange="this.form.submit()" />
      <a class="btn btn-secundario btn-sm" href="/painel/caixa?mes=<%= mesProximo %>" title="Próximo mês">→</a>
    </form>
  </div>

  <% if (lancamentos.length === 0) { %>
    <p class="texto-secundario mt-16">Nenhum lançamento neste mês.</p>
  <% } else { %>
    <div class="tabela-rolagem">
      <table class="tabela mt-16">
        <thead>
          <tr><th>Data</th><th>Descrição</th><th>Categoria</th><th class="col-valor">Valor</th><th></th></tr>
        </thead>
        <tbody>
          <% lancamentos.forEach(function (l) { %>
            <tr>
              <td><%= fmtData(l.data) %></td>
              <td><%= l.descricao %><% if (l.agendamentoId) { %> <span class="texto-sutil">(auto)</span><% } %></td>
              <td><%= l.categoria ? l.categoria.nome : '—' %></td>
              <td class="col-valor <%= l.tipo === 'entrada' ? 'valor-entrada' : 'valor-saida' %>">
                <%= l.tipo === 'entrada' ? '+' : '−' %><%= fmtBRL(l.valor) %>
              </td>
              <td class="col-acao">
                <form method="POST" action="/painel/caixa/<%= l.id %>/remover" class="inline"
                      onsubmit="return confirm('Excluir este lançamento?')">
                  <button class="btn-x" title="Excluir">×</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<!-- Categorias de caixa -->
<div class="card mt-16">
  <h2>Categorias de caixa</h2>
  <p class="texto-secundario mb-16">Cada categoria é de entrada ou saída. Remover não apaga lançamentos.</p>

  <form method="POST" action="/painel/caixa/categorias" class="form-cat-caixa">
    <input name="nome" placeholder="Nova categoria" required />
    <select name="tipo">
      <option value="entrada">Entrada</option>
      <option value="saida">Saída</option>
    </select>
    <button class="btn btn-secundario btn-sm">Adicionar</button>
  </form>

  <ul class="lista-categorias mt-16">
    <% categorias.forEach(function (c) { %>
      <li>
        <form method="POST" action="/painel/caixa/categorias/<%= c.id %>" class="form-cat-caixa">
          <input name="nome" value="<%= c.nome %>" />
          <select name="tipo">
            <option value="entrada" <%= c.tipo === 'entrada' ? 'selected' : '' %>>Entrada</option>
            <option value="saida" <%= c.tipo === 'saida' ? 'selected' : '' %>>Saída</option>
          </select>
          <span class="texto-sutil"><%= c._count.lancamentos %></span>
          <button class="btn btn-secundario btn-sm">Salvar</button>
        </form>
        <form method="POST" action="/painel/caixa/categorias/<%= c.id %>/remover" class="inline"
              onsubmit="return confirm('Remover esta categoria?')">
          <button class="btn-x" title="Remover categoria">×</button>
        </form>
      </li>
    <% }) %>
    <% if (categorias.length === 0) { %>
      <li class="texto-secundario">Nenhuma categoria.</li>
    <% } %>
  </ul>
</div>
