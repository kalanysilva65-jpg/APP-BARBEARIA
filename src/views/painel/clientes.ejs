<input type="search" id="busca-cliente" placeholder="Buscar cliente…" class="mb-16 input-busca" oninput="filtrarClientes(this.value)" />

<% if (clientes.length === 0) { %>
  <p class="texto-secundario">Nenhum cliente cadastrado ainda.</p>
<% } else { %>
  <div class="linha-simples-lista" id="lista-clientes">
    <% clientes.forEach(function (c) { %>
      <a href="/painel/clientes/<%= c.id %>" class="linha-simples" data-nome="<%= c.nome.toLowerCase() %>">
        <span class="avatar" style="width:32px;height:32px;font-size:11px"><%= c.nome.split(' ').length > 1 ? (c.nome[0] + c.nome.split(' ').slice(-1)[0][0]).toUpperCase() : c.nome.slice(0, 2).toUpperCase() %></span>
        <span class="linha-simples-info">
          <span class="linha-simples-titulo"><%= c.nome %></span>
          <span class="linha-simples-sub"><%= fmtTelefone(c.telefone) %></span>
        </span>
      </a>
    <% }) %>
  </div>
<% } %>

<!-- Botão flutuante: Novo cliente (só nesta tela) -->
<div class="agenda-fab-wrap">
  <button type="button" class="agenda-fab" onclick="abrirModal('cliente')" aria-label="Novo cliente">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
</div>

<div class="ag-overlay" id="agm-cliente" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome"><%= editando ? 'Editar cliente' : 'Novo cliente' %></div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <form method="POST" class="form mt-16"
          action="<%= editando ? '/painel/clientes/' + editando.id : '/painel/clientes' %>">
      <div class="campo">
        <label for="nome">Nome</label>
        <input id="nome" name="nome" value="<%= editando ? editando.nome : '' %>" required />
      </div>
      <div class="campo">
        <label for="telefone">Telefone</label>
        <input id="telefone" name="telefone" inputmode="tel" placeholder="(51) 99999-9999"
               value="<%= editando ? fmtTelefone(editando.telefone) : '' %>" required />
      </div>
      <div class="campo">
        <label for="dataNascimento">Data de nascimento (opcional)</label>
        <input id="dataNascimento" type="date" name="dataNascimento"
               value="<%= editando && editando.dataNascimento ? new Date(editando.dataNascimento).toISOString().slice(0, 10) : '' %>" />
      </div>
      <button class="btn btn-primario btn-bloco" type="submit">
        <%= editando ? 'Salvar' : 'Cadastrar' %>
      </button>
    </form>
  </div>
</div>

<script>
  function abrirModal(id) {
    var o = document.getElementById('agm-' + id);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  function filtrarClientes(termo) {
    var t = termo.trim().toLowerCase();
    document.querySelectorAll('#lista-clientes .linha-simples').forEach(function (r) {
      r.style.display = r.dataset.nome.indexOf(t) === -1 ? 'none' : 'flex';
    });
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
  <% if (editando) { %>abrirModal('cliente');<% } %>
</script>
