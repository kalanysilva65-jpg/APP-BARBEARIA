<div class="cabecalho-pagina">
  <h1>Equipe</h1>
  <a href="/painel/equipe/novo" class="btn btn-primario">+ Novo barbeiro</a>
</div>

<div class="lista-cards">
  <% membros.forEach(m => { %>
    <div class="card card-linha">
      <div class="card-linha-info">
        <span class="card-titulo"><%= m.nome %></span>
        <span class="texto-sutil"><%= m.email %></span>
      </div>
      <div class="card-linha-acoes" style="display:flex;align-items:center;gap:10px">
        <span class="badge-papel" style="<%= m.ativo ? '' : 'opacity:0.4' %>">
          <%= m.papel === 'admin' ? 'Admin' : 'Barbeiro' %>
        </span>
        <% if (!m.ativo) { %>
          <span class="badge badge-inativo">Inativo</span>
        <% } %>
        <a href="/painel/equipe/<%= m.id %>/editar" class="btn btn-secundario btn-sm">Editar</a>
        <% if (m.id !== usuario.id) { %>
          <form method="POST" action="/painel/equipe/<%= m.id %>/toggle">
            <button type="submit" class="btn btn-sm <%= m.ativo ? 'btn-perigo' : 'btn-secundario' %>">
              <%= m.ativo ? 'Desativar' : 'Reativar' %>
            </button>
          </form>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
