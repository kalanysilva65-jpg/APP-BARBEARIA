<a href="/painel/agenda" class="link-voltar">← Voltar para a agenda</a>

<div class="cabecalho-pagina">
  <h1>Novo agendamento</h1>
</div>

<% if (erro) { %>
  <div class="alerta alerta-erro"><%= erro %></div>
<% } %>

<div class="card">
  <form method="POST" action="/painel/agenda/novo" class="form">
    <% if (ehAdmin) { %>
      <div class="campo">
        <label for="barbeiroId">Barbeiro</label>
        <select id="barbeiroId" name="barbeiroId" required>
          <option value="">Selecione…</option>
          <% barbeiros.forEach(function (b) { %>
            <option value="<%= b.id %>" <%= valores && String(valores.barbeiroId) === String(b.id) ? 'selected' : '' %>><%= b.nome %></option>
          <% }) %>
        </select>
      </div>
    <% } else { %>
      <p class="texto-secundario mb-16">Agendamento para você (<%= usuario.nome %>).</p>
    <% } %>

    <div class="campo">
      <label for="servicoId">Serviço</label>
      <select id="servicoId" name="servicoId" required>
        <option value="">Selecione…</option>
        <% servicos.forEach(function (s) { %>
          <option value="<%= s.id %>" <%= valores && String(valores.servicoId) === String(s.id) ? 'selected' : '' %>>
            <%= s.nome %> — <%= fmtBRL(s.valor) %><%= s.duracaoMin > 0 ? ' (' + s.duracaoMin + ' min)' : '' %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="grid-2">
      <div class="campo">
        <label for="data">Data</label>
        <input id="data" type="date" name="data" required
               value="<%= valores && valores.data ? valores.data : hojeIso %>" />
      </div>
      <div class="campo">
        <label for="hora">Horário</label>
        <input id="hora" type="time" name="hora" required
               value="<%= valores && valores.hora ? valores.hora : '' %>" />
      </div>
    </div>

    <div class="campo autocomplete">
      <label for="cliente_nome">Cliente</label>
      <input id="cliente_nome" name="cliente_nome" autocomplete="off" placeholder="Digite o nome (sugere cadastrados)"
             required value="<%= valores && valores.cliente_nome ? valores.cliente_nome : '' %>" />
      <div id="sugestoes-cliente" class="sugestoes"></div>
    </div>

    <div class="grid-2">
      <div class="campo">
        <label for="cliente_telefone">Telefone</label>
        <input id="cliente_telefone" name="cliente_telefone" inputmode="tel" placeholder="(51) 99999-9999"
               required value="<%= valores && valores.cliente_telefone ? valores.cliente_telefone : '' %>" />
      </div>
      <div class="campo">
        <label for="cliente_email">E-mail (opcional)</label>
        <input id="cliente_email" type="email" name="cliente_email"
               value="<%= valores && valores.cliente_email ? valores.cliente_email : '' %>" />
      </div>
    </div>

    <button class="btn btn-primario btn-bloco" type="submit">Criar agendamento</button>
  </form>
</div>

<script>
  (function () {
    var clientes = <%- JSON.stringify(clientes) %>;
    var inputNome = document.getElementById('cliente_nome');
    var inputTel = document.getElementById('cliente_telefone');
    var box = document.getElementById('sugestoes-cliente');

    function fmtTel(d) {
      d = (d || '').replace(/\D/g, '');
      if (d.length === 11) return '(' + d.slice(0, 2) + ') ' + d.slice(2, 7) + '-' + d.slice(7);
      if (d.length === 10) return '(' + d.slice(0, 2) + ') ' + d.slice(2, 6) + '-' + d.slice(6);
      return d;
    }
    function escapar(t) {
      return String(t).replace(/[&<>"]/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
      });
    }
    function fechar() { box.innerHTML = ''; box.style.display = 'none'; }
    function buscar(q) {
      q = q.trim().toLowerCase();
      if (!q) return [];
      var qDig = q.replace(/\D/g, '');
      return clientes.filter(function (c) {
        var nomeOk = c.nome.toLowerCase().indexOf(q) !== -1;
        var telOk = qDig && c.telefone.indexOf(qDig) !== -1;
        return nomeOk || telOk;
      }).slice(0, 8);
    }
    function render(lista) {
      if (!lista.length) { fechar(); return; }
      box.innerHTML = lista.map(function (c) {
        return '<button type="button" class="sugestao" data-nome="' + escapar(c.nome) +
          '" data-tel="' + c.telefone + '"><strong>' + escapar(c.nome) +
          '</strong><span>' + fmtTel(c.telefone) + '</span></button>';
      }).join('');
      box.style.display = 'block';
      Array.prototype.forEach.call(box.querySelectorAll('.sugestao'), function (btn) {
        btn.addEventListener('click', function () {
          inputNome.value = btn.getAttribute('data-nome');
          inputTel.value = fmtTel(btn.getAttribute('data-tel'));
          fechar();
          inputTel.focus();
        });
      });
    }
    inputNome.addEventListener('input', function () { render(buscar(inputNome.value)); });
    inputNome.addEventListener('focus', function () { render(buscar(inputNome.value)); });
    document.addEventListener('click', function (e) {
      if (!box.contains(e.target) && e.target !== inputNome) fechar();
    });
  })();
</script>
