<a href="/painel/servicos" class="link-voltar">← Voltar</a>

<div class="cabecalho-pagina">
  <h1><%= servico ? 'Editar serviço' : 'Novo serviço' %></h1>
</div>

<div class="card">
  <form method="POST" enctype="multipart/form-data" class="form"
        action="<%= servico ? '/painel/servicos/' + servico.id : '/painel/servicos' %>">

    <div class="campo">
      <label for="nome">Nome</label>
      <input id="nome" name="nome" value="<%= servico ? servico.nome : '' %>" required autofocus />
    </div>

    <div class="grid-2">
      <div class="campo">
        <label for="valor">Valor (R$)</label>
        <input id="valor" name="valor" type="number" step="0.01" min="0"
               value="<%= servico ? (servico.valor / 100).toFixed(2) : '' %>" required />
      </div>
      <div class="campo">
        <label for="duracaoMin">Duração (min)</label>
        <input id="duracaoMin" name="duracaoMin" type="number" min="0"
               value="<%= servico ? servico.duracaoMin : 0 %>" />
      </div>
    </div>
    <p class="texto-sutil" style="margin-top: -8px; margin-bottom: 16px">
      Use duração <strong>0</strong> para produtos (não ocupam horário na agenda).
    </p>

    <div class="campo">
      <label for="categoriaId">Categoria</label>
      <select id="categoriaId" name="categoriaId">
        <option value="">Sem categoria</option>
        <% categorias.forEach(function (c) { %>
          <option value="<%= c.id %>" <%= servico && servico.categoriaId === c.id ? 'selected' : '' %>><%= c.nome %></option>
        <% }) %>
      </select>
    </div>

    <div class="campo">
      <label for="foto">Foto</label>
      <% if (servico && servico.fotoUrl) { %>
        <div class="preview-foto"><img src="<%= servico.fotoUrl %>" alt="Foto atual" /></div>
      <% } %>
      <input id="foto" name="foto" type="file" accept="image/*" />
      <span class="texto-sutil">
        JPG, PNG ou WEBP, até 4 MB.<%= servico && servico.fotoUrl ? ' Enviar uma nova substitui a atual.' : '' %>
      </span>
    </div>

    <button class="btn btn-primario btn-bloco" type="submit">
      <%= servico ? 'Salvar alterações' : 'Criar serviço' %>
    </button>
  </form>
</div>
