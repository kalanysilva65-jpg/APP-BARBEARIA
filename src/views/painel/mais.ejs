<div class="perfil-topo">
  <span class="avatar avatar--xl">
    <% if (usuario.fotoUrl) { %><img src="<%= usuario.fotoUrl %>" alt="Foto de <%= usuario.nome %>" style="width:100%;height:100%;border-radius:50%;object-fit:cover;" /><% } else { %><%= usuario.nome.charAt(0).toUpperCase() %><% } %>
  </span>
  <div>
    <div class="perfil-nome"><%= usuario.nome %></div>
    <div class="perfil-cargo"><%= ehDono ? 'Dono do sistema' : (usuario.papel === 'admin' ? 'Admin' : 'Barbeiro') %></div>
  </div>
</div>

<% if (usuario.barbeariaId) { %>
  <div class="perfil-linha" style="justify-content:center;padding:16px 0;">
    <div style="text-align:center;">
      <div class="perfil-nome" style="font-size:16px;"><%= atendimentos %></div>
      <div class="perfil-cargo" style="text-transform:none;letter-spacing:0;">Atendimentos</div>
    </div>
  </div>
  <div class="perfil-linha">
    <span class="perfil-linha-label">Horário de trabalho</span>
    <span class="perfil-linha-valor"><%= horarioTrabalho %></span>
  </div>
<% } %>
<div class="perfil-linha">
  <span class="perfil-linha-label">Barbearia</span>
  <span class="perfil-linha-valor"><%= barbeariaAtual ? barbeariaAtual.nome : '—' %></span>
</div>

<form method="POST" action="/logout">
  <button class="perfil-sair" type="submit">Sair</button>
</form>
