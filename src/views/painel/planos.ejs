<%
  var DIAS_ABREV = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
  var DIAS_LETRA = ['D', 'S', 'T', 'Q', 'Q', 'S', 'S'];
  function _diasArr(diasStr) {
    return String(diasStr || '0,1,2,3,4,5,6').split(',').map(Number).filter(function (n) { return !isNaN(n); });
  }
  function _diasLabel(diasStr) {
    var dias = _diasArr(diasStr).slice().sort(function (a, b) { return a - b; });
    if (dias.length === 7) return 'Todos os dias';
    return dias.map(function (d) { return DIAS_ABREV[d]; }).join(', ');
  }
%>

<div class="cards-grid" style="grid-template-columns:1fr;gap:10px;">
  <% planos.forEach(function (p) { %>
    <div class="item-card plano-card" <% if (ehAdmin) { %>onclick="abrirModal(<%= p.id %>)" style="cursor:pointer"<% } %>>
      <% if (ehAdmin) { %>
        <button type="button" class="plano-card-editar" title="Editar" onclick="event.stopPropagation();abrirModal(<%= p.id %>)">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        </button>
      <% } %>
      <div class="plano-card-topo">
        <span class="plano-card-nome"><%= p.nome %></span>
        <span class="plano-badge <%= p.tipo === 'ilimitado' ? 'plano-badge--ilimitado' : 'plano-badge--limitado' %>"><%= p.tipo %></span>
      </div>
      <div class="plano-card-preco"><span class="n"><%= fmtBRL(p.valor) %></span><span class="u">/mês</span></div>
      <div class="plano-card-desc">
        <%= _diasLabel(p.diasSemana) %> · <%= p.tipo === 'limitado' ? p.usos + 'x por mês' : 'Uso ilimitado' %> · <%= p.servico ? p.servico.nome : 'qualquer serviço' %><% if (!p.ativo) { %> · <span class="status status-cancelado">inativo</span><% } %>
      </div>
    </div>
  <% }) %>

  <% if (planos.length === 0) { %>
    <div class="card">
      <p class="texto-secundario">
        Nenhum plano cadastrado<%= ehAdmin ? ' ainda. Toque no + para criar.' : '.' %>
      </p>
    </div>
  <% } %>
</div>

<% if (ehAdmin) { %>
  <!-- Botão flutuante: Novo plano (só nesta tela) -->
  <div class="agenda-fab-wrap">
    <button type="button" class="agenda-fab" onclick="abrirModal('novo')" aria-label="Novo plano">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>
  </div>

  <!-- Pop-up: novo plano -->
  <div class="ag-overlay" id="agm-novo" onclick="if(event.target===this)fecharModal(this)">
    <div class="ag-modal-box">
      <div class="ag-modal-topo">
        <div class="ag-modal-nome">Novo plano</div>
      </div>
      <form method="POST" class="form mt-16" action="/painel/planos">
        <div class="campo">
          <label for="nome-novo">Nome</label>
          <input id="nome-novo" name="nome" required />
        </div>
        <div class="campo">
          <label for="valor-novo">Valor (R$)</label>
          <input id="valor-novo" name="valor" type="number" step="0.01" min="0" />
        </div>

        <div class="campo">
          <label>Tipo de uso</label>
          <input type="hidden" name="tipo" id="tipo-novo" value="limitado" />
          <div class="pill-group">
            <button type="button" class="pill-opcao" data-valor="ilimitado" onclick="selecionarTipo(this,'novo')">Ilimitado</button>
            <button type="button" class="pill-opcao ativo" data-valor="limitado" onclick="selecionarTipo(this,'novo')">Limitado</button>
          </div>
        </div>

        <div class="campo" id="campo-usos-novo">
          <label for="usos-novo">Nº de usos por mês</label>
          <input id="usos-novo" name="usos" type="number" min="1" value="1" />
        </div>

        <div class="campo">
          <label>Dias disponíveis</label>
          <input type="hidden" name="diasSemana" id="dias-novo" value="0,1,2,3,4,5,6" />
          <div class="dias-semana-group" id="dias-group-novo">
            <% DIAS_LETRA.forEach(function (letra, i) { %>
              <button type="button" class="dia-pill ativo" data-dia="<%= i %>" onclick="alternarDia(this,'novo')"><%= letra %></button>
            <% }) %>
          </div>
        </div>

        <div class="campo">
          <label for="servicoId-novo">Serviço incluso</label>
          <select id="servicoId-novo" name="servicoId">
            <option value="">Qualquer serviço</option>
            <% servicos.forEach(function (s) { %>
              <option value="<%= s.id %>"><%= s.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="campo">
          <label for="validadeDias-novo">Validade (dias)</label>
          <input id="validadeDias-novo" name="validadeDias" type="number" min="1" value="30" />
        </div>

        <div class="modal-acoes">
          <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
          <button class="btn btn-primario" type="submit">Criar plano</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Pop-up de edição: um por plano -->
  <% planos.forEach(function (p) { %>
    <div class="ag-overlay" id="agm-<%= p.id %>" onclick="if(event.target===this)fecharModal(this)">
      <div class="ag-modal-box">
        <div class="ag-modal-topo">
          <div class="ag-modal-nome">Editar plano</div>
        </div>
        <form method="POST" class="form mt-16" action="/painel/planos/<%= p.id %>">
          <div class="campo">
            <label for="nome-<%= p.id %>">Nome</label>
            <input id="nome-<%= p.id %>" name="nome" value="<%= p.nome %>" required />
          </div>
          <div class="campo">
            <label for="valor-<%= p.id %>">Valor (R$)</label>
            <input id="valor-<%= p.id %>" name="valor" type="number" step="0.01" min="0" value="<%= (p.valor / 100).toFixed(2) %>" />
          </div>

          <div class="campo">
            <label>Tipo de uso</label>
            <input type="hidden" name="tipo" id="tipo-<%= p.id %>" value="<%= p.tipo %>" />
            <div class="pill-group">
              <button type="button" class="pill-opcao <%= p.tipo === 'ilimitado' ? 'ativo' : '' %>" data-valor="ilimitado" onclick="selecionarTipo(this,'<%= p.id %>')">Ilimitado</button>
              <button type="button" class="pill-opcao <%= p.tipo === 'limitado' ? 'ativo' : '' %>" data-valor="limitado" onclick="selecionarTipo(this,'<%= p.id %>')">Limitado</button>
            </div>
          </div>

          <div class="campo" id="campo-usos-<%= p.id %>" style="display:<%= p.tipo === 'ilimitado' ? 'none' : '' %>">
            <label for="usos-<%= p.id %>">Nº de usos por mês</label>
            <input id="usos-<%= p.id %>" name="usos" type="number" min="1" value="<%= p.usos || 1 %>" />
          </div>

          <div class="campo">
            <label>Dias disponíveis</label>
            <input type="hidden" name="diasSemana" id="dias-<%= p.id %>" value="<%= p.diasSemana %>" />
            <div class="dias-semana-group" id="dias-group-<%= p.id %>">
              <% var diasAtivos = _diasArr(p.diasSemana); %>
              <% DIAS_LETRA.forEach(function (letra, i) { %>
                <button type="button" class="dia-pill <%= diasAtivos.indexOf(i) !== -1 ? 'ativo' : '' %>" data-dia="<%= i %>" onclick="alternarDia(this,'<%= p.id %>')"><%= letra %></button>
              <% }) %>
            </div>
          </div>

          <div class="campo">
            <label for="servicoId-<%= p.id %>">Serviço incluso</label>
            <select id="servicoId-<%= p.id %>" name="servicoId">
              <option value="">Qualquer serviço</option>
              <% servicos.forEach(function (s) { %>
                <option value="<%= s.id %>" <%= p.servicoId === s.id ? 'selected' : '' %>><%= s.nome %></option>
              <% }) %>
            </select>
          </div>
          <div class="campo">
            <label for="validadeDias-<%= p.id %>">Validade (dias)</label>
            <input id="validadeDias-<%= p.id %>" name="validadeDias" type="number" min="1" value="<%= p.validadeDias %>" />
          </div>

          <div class="modal-acoes">
            <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
            <button class="btn btn-primario" type="submit">Salvar</button>
          </div>
        </form>
        <div class="flex gap-8 mt-16">
          <form method="POST" action="/painel/planos/<%= p.id %>/toggle" class="inline">
            <button class="btn btn-secundario btn-sm"><%= p.ativo ? 'Desativar' : 'Ativar' %></button>
          </form>
          <form method="POST" action="/painel/planos/<%= p.id %>/remover" class="inline"
                onsubmit="return confirm('Excluir este plano?')">
            <button class="btn btn-perigo btn-sm">Excluir</button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>

  <script>
    function abrirModal(id) {
      var o = document.getElementById('agm-' + id);
      if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
    }
    function fecharModal(o) {
      if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
    }
    // Tipo de uso: seleção única (Ilimitado/Limitado) — mostra/esconde "Nº de usos".
    function selecionarTipo(btn, id) {
      var grupo = btn.parentElement;
      Array.prototype.forEach.call(grupo.querySelectorAll('.pill-opcao'), function (b) { b.classList.remove('ativo'); });
      btn.classList.add('ativo');
      document.getElementById('tipo-' + id).value = btn.getAttribute('data-valor');
      var campoUsos = document.getElementById('campo-usos-' + id);
      if (campoUsos) campoUsos.style.display = btn.getAttribute('data-valor') === 'ilimitado' ? 'none' : '';
    }
    // Dias disponíveis: seleção múltipla (alterna cada dia).
    function alternarDia(btn, id) {
      btn.classList.toggle('ativo');
      var grupo = document.getElementById('dias-group-' + id);
      var dias = Array.prototype.filter.call(grupo.querySelectorAll('.dia-pill'), function (b) {
        return b.classList.contains('ativo');
      }).map(function (b) { return b.getAttribute('data-dia'); });
      document.getElementById('dias-' + id).value = dias.join(',');
    }
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
        document.body.classList.remove('modal-aberto');
      }
    });
  </script>
<% } %>
