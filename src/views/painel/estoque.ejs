<% if (baixoEstoque.length > 0) { %>
  <div class="alerta alerta-aviso mb-16">
    <strong>Reposição:</strong> <%= baixoEstoque.length %> item(ns) no mínimo ou abaixo —
    <%= baixoEstoque.map(function (i) { return i.nome + ' (' + i.quantidade + ')'; }).join(', ') %>.
  </div>
<% } %>

<div class="cards-grid">
  <% itens.forEach(function (i) { var baixo = i.quantidade <= i.quantidadeMinima; %>
    <div class="item-card <%= baixo ? 'item-card--baixo' : '' %>">
      <% if (baixo) { %><span class="badge-repor" style="position:absolute;top:10px;left:10px;z-index:1;">REPOR</span><% } %>
      <button type="button" class="item-edit-btn" title="Editar" onclick="abrirModal(<%= i.id %>)">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
      </button>
      <div class="item-thumb">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
      </div>
      <div class="item-info">
        <div class="item-bottom">
          <span class="row-title"><%= i.nome %></span>
          <span class="item-numero"><%= i.quantidade %></span>
        </div>
        <div class="item-categoria"><%= i.categoria ? i.categoria.nome : 'Sem categoria' %> · Mín. <%= i.quantidadeMinima %></div>
      </div>
    </div>
  <% }) %>

  <% if (itens.length === 0) { %>
    <div class="card"><p class="texto-secundario">Nenhum item no estoque ainda.</p></div>
  <% } %>
</div>

<!-- Categorias -->
<div class="card mt-24">
  <h2>Categorias de estoque</h2>
  <p class="texto-secundario mb-16">
    Remover uma categoria não apaga os itens — eles ficam "sem categoria".
  </p>

  <form method="POST" action="/painel/estoque/categorias" class="form-inline-cat">
    <input name="nome" placeholder="Nova categoria" required />
    <button class="btn btn-secundario btn-sm">Adicionar</button>
  </form>

  <ul class="lista-categorias mt-16">
    <% categorias.forEach(function (c) { %>
      <li>
        <form method="POST" action="/painel/estoque/categorias/<%= c.id %>" class="form-inline-cat">
          <input name="nome" value="<%= c.nome %>" />
          <span class="texto-sutil"><%= c._count.itens %> item(ns)</span>
          <button class="btn btn-secundario btn-sm">Salvar</button>
        </form>
        <form method="POST" action="/painel/estoque/categorias/<%= c.id %>/remover" class="inline"
              onsubmit="return confirm('Remover esta categoria?')">
          <button class="btn-x" title="Remover categoria">×</button>
        </form>
      </li>
    <% }) %>
    <% if (categorias.length === 0) { %>
      <li class="texto-secundario">Nenhuma categoria.</li>
    <% } %>
  </ul>
</div>

<!-- Botão flutuante: Novo item (só nesta tela) -->
<div class="agenda-fab-wrap">
  <button type="button" class="agenda-fab" onclick="abrirModal('novo')" aria-label="Novo item de estoque">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
  </button>
</div>

<!-- Pop-up: novo item -->
<div class="ag-overlay" id="agm-novo" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Novo item de estoque</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <form method="POST" class="form mt-16" action="/painel/estoque">
      <div class="campo">
        <label for="nome-novo">Nome</label>
        <input id="nome-novo" name="nome" required />
      </div>
      <div class="campo">
        <label for="categoriaId-novo">Categoria</label>
        <select id="categoriaId-novo" name="categoriaId">
          <option value="">Sem categoria</option>
          <% categorias.forEach(function (c) { %>
            <option value="<%= c.id %>"><%= c.nome %></option>
          <% }) %>
        </select>
      </div>
      <div class="grid-2">
        <div class="campo">
          <label for="quantidade-novo">Quantidade atual</label>
          <input id="quantidade-novo" name="quantidade" type="number" min="0" value="0" />
        </div>
        <div class="campo">
          <label for="quantidadeMinima-novo">Mínimo (alerta)</label>
          <input id="quantidadeMinima-novo" name="quantidadeMinima" type="number" min="0" value="0" />
        </div>
      </div>
      <div class="campo">
        <label for="valorGasto-novo">Valor gasto na compra (R$)</label>
        <input id="valorGasto-novo" name="valorGasto" type="number" step="0.01" min="0" />
      </div>
      <div class="modal-acoes">
        <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
        <button class="btn btn-primario" type="submit">Adicionar ao estoque</button>
      </div>
    </form>
  </div>
</div>

<!-- Pop-up de edição: um por item -->
<% itens.forEach(function (i) { %>
  <div class="ag-overlay" id="agm-<%= i.id %>" onclick="if(event.target===this)fecharModal(this)">
    <div class="ag-modal-box">
      <div class="ag-modal-topo">
        <div class="ag-modal-nome"><%= i.nome %></div>
        <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
      </div>
      <form method="POST" class="form mt-16" action="/painel/estoque/<%= i.id %>">
        <div class="campo">
          <label for="nome-<%= i.id %>">Nome</label>
          <input id="nome-<%= i.id %>" name="nome" value="<%= i.nome %>" required />
        </div>
        <div class="campo">
          <label for="categoriaId-<%= i.id %>">Categoria</label>
          <select id="categoriaId-<%= i.id %>" name="categoriaId">
            <option value="">Sem categoria</option>
            <% categorias.forEach(function (c) { %>
              <option value="<%= c.id %>" <%= i.categoriaId === c.id ? 'selected' : '' %>><%= c.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="grid-2">
          <div class="campo">
            <label for="quantidade-<%= i.id %>">Quantidade atual</label>
            <input id="quantidade-<%= i.id %>" name="quantidade" type="number" min="0" value="<%= i.quantidade %>" />
          </div>
          <div class="campo">
            <label for="quantidadeMinima-<%= i.id %>">Mínimo (alerta)</label>
            <input id="quantidadeMinima-<%= i.id %>" name="quantidadeMinima" type="number" min="0" value="<%= i.quantidadeMinima %>" />
          </div>
        </div>
        <div class="campo">
          <label for="valorGasto-<%= i.id %>">Valor gasto na compra (R$)</label>
          <input id="valorGasto-<%= i.id %>" name="valorGasto" type="number" step="0.01" min="0" value="<%= (i.valorGasto / 100).toFixed(2) %>" />
        </div>
        <div class="modal-acoes">
          <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
          <button class="btn btn-primario" type="submit">Salvar alterações</button>
        </div>
      </form>
      <form method="POST" action="/painel/estoque/<%= i.id %>/remover" class="mt-16"
            onsubmit="return confirm('Excluir este item?')">
        <button type="submit" class="btn btn-perigo">Excluir item</button>
      </form>
    </div>
  </div>
<% }) %>

<script>
  function abrirModal(id) {
    var o = document.getElementById('agm-' + id);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
</script>
