<%
  var nomeBarbearia = (typeof barbeariaAtual !== 'undefined' && barbeariaAtual) ? barbeariaAtual.nome : 'Barbearia';
%>

<!-- Cabeçalho: mesmo padrão da Agenda — sem cartão atrás, flutua no cinza
     contínuo da tela (descoberto relendo o style do próprio container do
     HTML: não havia background nenhum ali). -->
<div class="ag2-topo">
  <div class="ag2-marca-linha">
    <span class="ag2-avatar-deco"></span>
    <span class="ag2-marca"><%= nomeBarbearia %></span>
    <button type="button" class="ag2-add" onclick="abrirModal('novo')" aria-label="Novo item">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
    </button>
  </div>
  <div class="ag2-titulo">
    Estoque
    <% if (baixoEstoque.length > 0) { %>
      <span class="ag2-badge-alerta">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 9v4M12 17h.01"/><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>
        Estoque baixo
      </span>
    <% } %>
  </div>
</div>

<!-- Lista: cada item abre um POP-UP de vidro com os campos (diferente da
     Agenda, cujo detalhe expande dentro do próprio card — aqui é sempre um
     pop-up flutuante, como no HTML original). -->
<div class="ag2-corpo">
  <% if (itens.length === 0) { %>
    <div class="ag2-vazio">Nenhum item no estoque ainda.</div>
  <% } else { %>
    <div class="est-lista">
      <% itens.forEach(function (i) { var baixo = i.quantidade <= i.quantidadeMinima; %>
        <button type="button" class="est-item" onclick="abrirModal(<%= i.id %>)">
          <span class="est-avatar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
          </span>
          <span class="est-info">
            <span class="est-nome-linha">
              <span class="est-nome"><%= i.nome %></span>
              <% if (baixo) { %>
                <span class="est-badge-mini">
                  <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 9v4M12 17h.01"/><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>
                  Estoque baixo
                </span>
              <% } %>
            </span>
            <span class="est-sub"><%= i.quantidade %> un. · <%= i.categoria ? i.categoria.nome : 'Sem categoria' %></span>
          </span>
        </button>
      <% }) %>
    </div>
  <% } %>

  <!-- Categorias -->
  <div class="est-categorias">
    <div class="est-categorias-titulo">Categorias de estoque</div>
    <p class="est-categorias-sub">Remover uma categoria não apaga os itens — eles ficam "sem categoria".</p>
    <form method="POST" action="/painel/estoque/categorias" class="est-cat-form">
      <input name="nome" placeholder="Nova categoria" required />
      <button class="est-cat-btn" type="submit">Adicionar</button>
    </form>
    <% categorias.forEach(function (c) { %>
      <div class="est-cat-linha">
        <form method="POST" action="/painel/estoque/categorias/<%= c.id %>" class="est-cat-form">
          <input name="nome" value="<%= c.nome %>" />
          <span class="est-cat-count"><%= c._count.itens %></span>
          <button class="est-cat-btn est-cat-btn--claro" type="submit">Salvar</button>
        </form>
        <form method="POST" action="/painel/estoque/categorias/<%= c.id %>/remover" onsubmit="return confirm('Remover esta categoria?')">
          <button class="est-cat-x" title="Remover categoria">×</button>
        </form>
      </div>
    <% }) %>
    <% if (categorias.length === 0) { %><p class="est-categorias-sub">Nenhuma categoria.</p><% } %>
  </div>
</div>

<!-- Pop-up: novo item (vidro, mesmo padrão dos pop-ups da Agenda) -->
<div class="ag-overlay" id="agm-novo" onclick="if(event.target===this)fecharModal(this)">
  <div class="ag-modal-box">
    <div class="ag-modal-topo">
      <div class="ag-modal-nome">Novo item de estoque</div>
      <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
    </div>
    <form method="POST" class="form mt-16" action="/painel/estoque">
      <div class="campo">
        <label for="nome-novo">Nome</label>
        <input id="nome-novo" name="nome" required />
      </div>
      <div class="campo">
        <label for="categoriaId-novo">Categoria</label>
        <select id="categoriaId-novo" name="categoriaId">
          <option value="">Sem categoria</option>
          <% categorias.forEach(function (c) { %>
            <option value="<%= c.id %>"><%= c.nome %></option>
          <% }) %>
        </select>
      </div>
      <div class="grid-2">
        <div class="campo">
          <label for="quantidade-novo">Quantidade atual</label>
          <input id="quantidade-novo" name="quantidade" type="number" min="0" value="0" />
        </div>
        <div class="campo">
          <label for="quantidadeMinima-novo">Mínimo (alerta)</label>
          <input id="quantidadeMinima-novo" name="quantidadeMinima" type="number" min="0" value="0" />
        </div>
      </div>
      <div class="campo">
        <%/* O mockup chama esse campo de "Preço", mas o model não tem preço de
             venda — só o custo da compra. Rotulado como o app já usa, pra não
             sugerir que o item é vendido por esse valor. */%>
        <label for="valorGasto-novo">Valor gasto na compra (R$)</label>
        <input id="valorGasto-novo" name="valorGasto" type="number" step="0.01" min="0" />
      </div>
      <div class="modal-acoes">
        <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
        <button class="btn btn-primario" type="submit">Adicionar ao estoque</button>
      </div>
    </form>
  </div>
</div>

<!-- Pop-up de edição: um por item -->
<% itens.forEach(function (i) { %>
  <div class="ag-overlay" id="agm-<%= i.id %>" onclick="if(event.target===this)fecharModal(this)">
    <div class="ag-modal-box">
      <div class="ag-modal-topo">
        <div class="ag-modal-nome"><%= i.nome %></div>
        <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
      </div>
      <form method="POST" class="form mt-16" action="/painel/estoque/<%= i.id %>">
        <div class="campo">
          <label for="nome-<%= i.id %>">Nome</label>
          <input id="nome-<%= i.id %>" name="nome" value="<%= i.nome %>" required />
        </div>
        <div class="campo">
          <label for="categoriaId-<%= i.id %>">Categoria</label>
          <select id="categoriaId-<%= i.id %>" name="categoriaId">
            <option value="">Sem categoria</option>
            <% categorias.forEach(function (c) { %>
              <option value="<%= c.id %>" <%= i.categoriaId === c.id ? 'selected' : '' %>><%= c.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="grid-2">
          <div class="campo">
            <label for="quantidade-<%= i.id %>">Quantidade atual</label>
            <input id="quantidade-<%= i.id %>" name="quantidade" type="number" min="0" value="<%= i.quantidade %>" />
          </div>
          <div class="campo">
            <label for="quantidadeMinima-<%= i.id %>">Mínimo (alerta)</label>
            <input id="quantidadeMinima-<%= i.id %>" name="quantidadeMinima" type="number" min="0" value="<%= i.quantidadeMinima %>" />
          </div>
        </div>
        <div class="campo">
          <label for="valorGasto-<%= i.id %>">Valor gasto na compra (R$)</label>
          <input id="valorGasto-<%= i.id %>" name="valorGasto" type="number" step="0.01" min="0" value="<%= (i.valorGasto / 100).toFixed(2) %>" />
        </div>
        <div class="modal-acoes">
          <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
          <button class="btn btn-primario" type="submit">Salvar alterações</button>
        </div>
      </form>
      <form method="POST" action="/painel/estoque/<%= i.id %>/remover" class="mt-16"
            onsubmit="return confirm('Excluir este item?')">
        <button type="submit" class="btn btn-perigo">Excluir item</button>
      </form>
    </div>
  </div>
<% }) %>

<script>
  function abrirModal(id) {
    var o = document.getElementById('agm-' + id);
    if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
  }
  function fecharModal(o) {
    if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
  }
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
      document.body.classList.remove('modal-aberto');
    }
  });
</script>
