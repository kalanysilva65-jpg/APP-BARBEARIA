<% if (barbeiros.length === 0) { %>
  <div class="card"><p class="texto-secundario">Nenhum barbeiro ativo.</p></div>
<% } else { %>

  <span class="dash-rotulo texto-sutil">JANELA DE AGENDAMENTO DO CLIENTE</span>
  <p class="janela-desc">Controla até quando os clientes podem marcar horários pelo app.</p>
  <form method="POST" action="/painel/horarios/janela" class="janela-pills mb-24" id="form-janela">
    <button type="submit" name="janela" value="semana" class="janela-pill <%= janelaAgendamento === 'semana' ? 'ativo' : '' %>">Esta semana</button>
    <button type="submit" name="janela" value="duas_semanas" class="janela-pill <%= janelaAgendamento === 'duas_semanas' ? 'ativo' : '' %>">Esta e a próxima</button>
    <button type="submit" name="janela" value="sem_limite" class="janela-pill <%= janelaAgendamento === 'sem_limite' ? 'ativo' : '' %>">Sem limite</button>
  </form>

  <span class="dash-rotulo texto-sutil">JORNADA SEMANAL</span>
  <div class="linha-simples-lista mt-16 mb-24">
    <% barbeirosComJornada.forEach(function (bj) { %>
      <a href="#" class="linha-simples" onclick="abrirModal(<%= bj.barbeiro.id %>);return false;">
        <span class="linha-simples-info">
          <span class="linha-simples-titulo"><%= bj.barbeiro.nome %></span>
        </span>
        <span class="linha-simples-valor"><%= bj.resumo %></span>
        <span class="linha-simples-editar">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        </span>
      </a>
    <% }) %>
  </div>

  <div class="flex-fim" style="justify-content:space-between;">
    <span class="dash-rotulo texto-sutil">BLOQUEIOS MANUAIS</span>
    <button type="button" class="texto-secundario" style="font-size:12px;background:none;border:none;cursor:pointer;" onclick="abrirModal('bloqueio')">+ Adicionar</button>
  </div>
  <div class="linha-simples-lista mt-16">
    <% if (bloqueios.length === 0) { %>
      <p class="texto-secundario">Nenhum bloqueio futuro.</p>
    <% } else { %>
      <% bloqueios.forEach(function (bl) { %>
        <div class="linha-simples">
          <span class="linha-simples-info">
            <span class="linha-simples-titulo"><%= fmtData(bl.data) %> · <%= bl.horaInicio %>–<%= bl.horaFim %></span>
            <span class="linha-simples-sub"><%= bl.motivo || 'Bloqueado' %> · <%= bl.usuario.nome %></span>
          </span>
          <form method="POST" action="/painel/horarios/bloqueios/<%= bl.id %>/remover" class="linha-simples-x" onsubmit="return confirm('Remover este bloqueio?')">
            <button title="Remover bloqueio" type="submit">×</button>
          </form>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Pop-up: bloquear horário -->
  <div class="ag-overlay" id="agm-bloqueio" onclick="if(event.target===this)fecharModal(this)">
    <div class="ag-modal-box">
      <div class="ag-modal-topo">
        <div class="ag-modal-nome">Bloquear horário</div>
        <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
      </div>
      <form method="POST" action="/painel/horarios/bloqueios" class="form mt-16">
        <div class="campo">
          <label for="barbeiroId">Barbeiro</label>
          <select id="barbeiroId" name="barbeiroId" required>
            <% barbeiros.forEach(function (b) { %>
              <option value="<%= b.id %>"><%= b.nome %></option>
            <% }) %>
          </select>
        </div>
        <div class="campo">
          <label for="data">Data</label>
          <input id="data" type="date" name="data" required />
        </div>
        <div class="grid-2">
          <div class="campo">
            <label for="horaInicio">Início</label>
            <input id="horaInicio" type="time" name="horaInicio" required />
          </div>
          <div class="campo">
            <label for="horaFim">Fim</label>
            <input id="horaFim" type="time" name="horaFim" required />
          </div>
        </div>
        <div class="campo">
          <label for="motivo">Motivo (opcional)</label>
          <input id="motivo" name="motivo" placeholder="Almoço, compromisso…" />
        </div>
        <div class="modal-acoes">
          <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
          <button class="btn btn-primario">Adicionar bloqueio</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Pop-up: jornada semanal por barbeiro -->
  <% barbeirosComJornada.forEach(function (bj) { %>
    <div class="ag-overlay" id="agm-<%= bj.barbeiro.id %>" onclick="if(event.target===this)fecharModal(this)">
      <div class="ag-modal-box">
        <div class="ag-modal-topo">
          <div class="ag-modal-nome"><%= bj.barbeiro.nome %></div>
          <button class="ag-modal-fechar" type="button" onclick="fecharModal(this.closest('.ag-overlay'))" aria-label="Fechar">×</button>
        </div>
        <p class="texto-secundario mb-16">Desmarque um dia para fechar (folga).</p>
        <form method="POST" action="/painel/horarios/jornada">
          <input type="hidden" name="barbeiroId" value="<%= bj.barbeiro.id %>" />
          <table class="tabela tabela-jornada">
            <tbody>
              <% bj.jornada.forEach(function (j) { %>
                <tr>
                  <td>
                    <label class="check">
                      <input type="checkbox" name="trabalha_<%= j.diaSemana %>" <%= j.trabalha ? 'checked' : '' %> />
                      <%= DIAS_SEMANA[j.diaSemana] %>
                    </label>
                  </td>
                  <td><input type="time" name="inicio_<%= j.diaSemana %>" value="<%= j.horaInicio %>" /></td>
                  <td><input type="time" name="fim_<%= j.diaSemana %>" value="<%= j.horaFim %>" /></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
          <div class="modal-acoes mt-16">
            <button type="button" class="modal-cancelar" onclick="fecharModal(this.closest('.ag-overlay'))">Cancelar</button>
            <button class="btn btn-primario">Salvar jornada</button>
          </div>
        </form>
      </div>
    </div>
  <% }) %>

  <script>
    function abrirModal(id) {
      var o = document.getElementById('agm-' + id);
      if (o) { o.style.display = 'flex'; document.body.classList.add('modal-aberto'); }
    }
    function fecharModal(o) {
      if (o) { o.style.display = 'none'; document.body.classList.remove('modal-aberto'); }
    }
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.ag-overlay').forEach(function (o) { o.style.display = 'none'; });
        document.body.classList.remove('modal-aberto');
      }
    });
  </script>

<% } %>
