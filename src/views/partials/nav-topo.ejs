<div class="nav-topo-area">
  <div class="container">
    <div class="nav-topo-scroll">
      <div class="nav-topo-pills">
        <a href="/painel" class="nav-topo-pill <%= currentPath === '/painel' ? 'ativo' : '' %>">Início</a>
        <a href="/painel/agenda" class="nav-topo-pill <%= currentPath.startsWith('/painel/agenda') ? 'ativo' : '' %>">Agenda</a>
        <% if (ehAdmin) { %>
          <a href="/painel/servicos" class="nav-topo-pill <%= currentPath.startsWith('/painel/servicos') ? 'ativo' : '' %>">Serviços</a>
          <a href="/painel/estoque" class="nav-topo-pill <%= currentPath.startsWith('/painel/estoque') ? 'ativo' : '' %>">Estoque</a>
          <a href="/painel/caixa" class="nav-topo-pill <%= currentPath.startsWith('/painel/caixa') ? 'ativo' : '' %>">Financeiro</a>
          <a href="/painel/comissoes" class="nav-topo-pill <%= currentPath.startsWith('/painel/comissoes') ? 'ativo' : '' %>">Comissões</a>
          <a href="/painel/horarios" class="nav-topo-pill <%= currentPath.startsWith('/painel/horarios') ? 'ativo' : '' %>">Horários</a>
        <% } %>
        <a href="/painel/clientes" class="nav-topo-pill <%= currentPath.startsWith('/painel/clientes') ? 'ativo' : '' %>">Clientes</a>
        <a href="/painel/planos" class="nav-topo-pill <%= currentPath.startsWith('/painel/planos') ? 'ativo' : '' %>">Planos</a>
        <a href="/painel/mais" class="nav-topo-pill <%= currentPath.startsWith('/painel/mais') ? 'ativo' : '' %>">Perfil</a>
      </div>
    </div>
  </div>
</div>

<script>
  // No touch (celular) o scroll horizontal já funciona nativamente. No PC (mouse),
  // não há como "arrastar" a barra sem isso: permite clicar e arrastar para o lado.
  (function () {
    var el = document.querySelector('.nav-topo-scroll');
    if (!el) return;

    // Cada página é um carregamento novo (não é SPA), então a barra sempre
    // nasceria rolada lá no início — o que parece "voltar" pro usuário toda
    // vez que ele navega para uma aba mais à direita. Centraliza a aba ativa
    // já na primeira renderização, sem depender de scroll salvo/animação.
    var ativa = el.querySelector('.nav-topo-pill.ativo');
    if (ativa) {
      var alvo = ativa.offsetLeft - (el.clientWidth - ativa.offsetWidth) / 2;
      el.scrollLeft = Math.max(0, alvo);
    }

    var arrastando = false;
    var movido = false;
    var startX = 0;
    var startScroll = 0;

    el.addEventListener('mousedown', function (e) {
      arrastando = true;
      movido = false;
      startX = e.pageX;
      startScroll = el.scrollLeft;
      el.style.cursor = 'grabbing';
    });
    window.addEventListener('mouseup', function () {
      arrastando = false;
      el.style.cursor = '';
    });
    window.addEventListener('mousemove', function (e) {
      if (!arrastando) return;
      var dx = e.pageX - startX;
      if (Math.abs(dx) > 3) movido = true;
      el.scrollLeft = startScroll - dx;
    });
    // Evita que o clique no link dispare navegação quando o usuário só queria arrastar.
    el.addEventListener('click', function (e) {
      if (movido) { e.preventDefault(); e.stopPropagation(); }
    }, true);
    // Roda do mouse: permite rolar na horizontal mesmo sem Shift.
    el.addEventListener('wheel', function (e) {
      if (e.deltaY === 0) return;
      el.scrollLeft += e.deltaY;
      e.preventDefault();
    }, { passive: false });
  })();
</script>
