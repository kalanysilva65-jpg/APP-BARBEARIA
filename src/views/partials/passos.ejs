<%
  var ROTULOS_PASSO = { 1: 'Serviço', 2: 'Barbeiro', 3: 'Horário', 4: 'Dados' };
%>
<div class="passos-agendamento">
  <span class="passos-agendamento-label"><%= passo %> / 4 — <%= ROTULOS_PASSO[passo].toUpperCase() %></span>
  <div class="passos-agendamento-barra">
    <% for (var i = 1; i <= 4; i++) { %>
      <span class="passos-agendamento-seg <%= i <= passo ? 'feito' : '' %>"></span>
    <% } %>
  </div>
</div>
