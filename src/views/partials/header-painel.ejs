<header class="topo">
  <div class="container topo-inner">
    <a href="/painel" class="marca">Barbearia<span>.</span></a>
    <div class="topo-usuario">
      <span class="usuario-nome"><%= usuario.nome %></span>
      <span class="badge-papel"><%= usuario.papel === 'admin' ? 'Admin' : 'Funcionário' %></span>
      <form method="POST" action="/logout">
        <button class="btn btn-secundario btn-sm" type="submit">Sair</button>
      </form>
    </div>
  </div>

  <nav class="nav-principal">
    <div class="container nav-inner">
      <a href="/painel" class="<%= currentPath === '/painel' ? 'ativo' : '' %>">Painel</a>
      <a href="/painel/agenda" class="<%= currentPath.startsWith('/painel/agenda') ? 'ativo' : '' %>">Agenda</a>
      <% if (usuario.papel === 'admin') { %>
        <a href="/painel/servicos" class="<%= currentPath.startsWith('/painel/servicos') ? 'ativo' : '' %>">Serviços</a>
        <a href="/painel/estoque" class="<%= currentPath.startsWith('/painel/estoque') ? 'ativo' : '' %>">Estoque</a>
        <a href="/painel/caixa" class="<%= currentPath.startsWith('/painel/caixa') ? 'ativo' : '' %>">Caixa</a>
        <a href="/painel/horarios" class="<%= currentPath.startsWith('/painel/horarios') ? 'ativo' : '' %>">Horários</a>
      <% } %>
    </div>
  </nav>
</header>
