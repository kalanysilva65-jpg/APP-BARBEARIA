<%
  // Abas do painel. `admin: true` = só o dono/admin enxerga.
  // Os ícones não têm rótulo visível, então `title` (tooltip) e `aria-label`
  // são a única forma de descobrir o destino — nunca remova os dois.
  var abas = [
    { href: '/painel',           nome: 'Início',     exato: true },
    { href: '/painel/agenda',    nome: 'Agenda' },
    { href: '/painel/servicos',  nome: 'Serviços' },
    { href: '/painel/estoque',   nome: 'Estoque' },
    { href: '/painel/planos',    nome: 'Planos' },
    { href: '/painel/caixa',     nome: 'Financeiro', admin: true },
    { href: '/painel/comissoes', nome: 'Comissões' },
    { href: '/painel/horarios',  nome: 'Horários' },
    { href: '/painel/clientes',  nome: 'Clientes' },
    { href: '/painel/mais',      nome: 'Perfil' },
  ];

  var icones = {
    'Início':     '<path d="M3 10.5 12 3l9 7.5V20a1 1 0 0 1-1 1h-5v-6H9v6H4a1 1 0 0 1-1-1z"/>',
    'Agenda':     '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 11h18"/>',
    'Serviços':   '<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M20 4 8.12 15.88M14.47 14.48 20 20M8.12 8.12 12 12"/>',
    'Estoque':    '<path d="M21 8 12 3 3 8v8l9 5 9-5z"/><path d="M3 8l9 5 9-5M12 13v8"/>',
    'Planos':     '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>',
    'Financeiro': '<path d="M12 2v20"/><path d="M17 6.5c0-2-2.2-3-5-3s-5 .9-5 2.9c0 4.3 10 2 10 6.2 0 2.1-2.2 3.1-5 3.1s-5-1-5-3"/>',
    'Comissões':  '<path d="M19 5 5 19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/>',
    'Horários':   '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
    'Clientes':   '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/>',
    'Perfil':     '<circle cx="12" cy="8" r="4"/><path d="M4 21v-1a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v1"/>',
  };

  function ativa(aba) {
    return aba.exato ? currentPath === aba.href : currentPath.indexOf(aba.href) === 0;
  }
%>
<nav class="nav-inf" aria-label="Navegação do painel">
  <div class="nav-inf-scroll">
    <% abas.forEach(function (aba) { %>
      <% if (!aba.admin || ehAdmin) { %>
        <a
          href="<%= aba.href %>"
          class="nav-inf-item <%= ativa(aba) ? 'ativo' : '' %>"
          title="<%= aba.nome %>"
          aria-label="<%= aba.nome %>"
          <%= ativa(aba) ? 'aria-current="page"' : '' %>
        >
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><%- icones[aba.nome] %></svg>
        </a>
      <% } %>
    <% }) %>
  </div>
</nav>

<script>
  // A barra rola na horizontal (não cabem 10 ícones na largura de um celular).
  // Cada página é um carregamento novo, então a barra nasceria sempre no início:
  // centraliza a aba ativa já na primeira renderização.
  (function () {
    var el = document.querySelector('.nav-inf-scroll');
    if (!el) return;
    var ativa = el.querySelector('.nav-inf-item.ativo');
    if (ativa) {
      var alvo = ativa.offsetLeft - (el.clientWidth - ativa.offsetWidth) / 2;
      el.scrollLeft = Math.max(0, alvo);
    }
  })();
</script>
