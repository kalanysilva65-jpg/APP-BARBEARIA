<div class="cabecalho-pagina">
  <h1>Nova barbearia</h1>
  <p class="texto-secundario">Cria a barbearia e o primeiro acesso de admin dela.</p>
</div>

<% if (erro) { %>
  <div class="alerta alerta-erro mb-16"><%= erro %></div>
<% } %>

<form method="POST" action="/mestre/barbearias" class="card form">
  <h2>Barbearia</h2>
  <div class="grid-2 mt-16">
    <div class="campo">
      <label for="nome">Nome</label>
      <input id="nome" name="nome" value="<%= valores ? valores.nome : '' %>" required autofocus />
    </div>
    <div class="campo">
      <label for="slug">Subdomínio</label>
      <input id="slug" name="slug" placeholder="ex.: andrade" value="<%= valores ? valores.slug : '' %>" />
      <span class="texto-sutil">Vira &lt;subdomínio&gt;.seuapp.com. Se vazio, é gerado a partir do nome.</span>
    </div>
  </div>

  <h2 class="mt-16">Admin da barbearia</h2>
  <div class="grid-2 mt-16">
    <div class="campo">
      <label for="adminNome">Nome</label>
      <input id="adminNome" name="adminNome" value="<%= valores ? valores.adminNome : '' %>" required />
    </div>
    <div class="campo">
      <label for="adminEmail">E-mail</label>
      <input id="adminEmail" type="email" name="adminEmail" value="<%= valores ? valores.adminEmail : '' %>" required />
    </div>
  </div>
  <div class="campo">
    <label for="adminSenha">Senha (mínimo 6 caracteres)</label>
    <input id="adminSenha" type="text" name="adminSenha" required />
  </div>

  <div class="flex gap-8 mt-16">
    <button class="btn btn-primario btn-sm" type="submit">Criar barbearia</button>
    <a href="/mestre" class="btn btn-secundario btn-sm">Cancelar</a>
  </div>
</form>
