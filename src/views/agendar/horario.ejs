<a href="/agendar/barbeiro?servicoIds=<%= servicoIdsStr %><%= assinatura ? '&assinatura=' + assinatura.id : '' %>"
   class="link-voltar">← Voltar</a>

<div class="cabecalho-pagina">
  <h1>Escolha o horário</h1>
  <p class="texto-secundario">
    Com <strong><%= barbeiro.nome %></strong> ·
    <% if (servicos.length === 1) { %><%= servicos[0].nome %><% } else { %><%= servicos.length %> serviços<% } %>
  </p>
</div>

<% if (ilimitado) { %>
  <div class="alerta alerta-aviso">Plano ilimitado: agendamento só de <strong>segunda a quinta</strong>.</div>
<% } %>

<% if (datas.length === 0) { %>
  <div class="card">
    <p class="texto-secundario">Sem datas disponíveis para este barbeiro<%= ilimitado ? ' de seg a qui' : '' %>.</p>
  </div>
<% } else { %>
  <label>Data</label>
  <div class="lista-datas">
    <% datas.forEach(function (d) { %>
      <a class="chip-data <%= d.iso === dataSel ? 'selecionado' : '' %>"
         href="/agendar/horario?servicoIds=<%= servicoIdsStr %>&barbeiroId=<%= barbeiro.id %>&data=<%= d.iso %><%= assinatura ? '&assinatura=' + assinatura.id : '' %>">
        <%= d.rotulo %>
      </a>
    <% }) %>
  </div>

  <label class="mt-24">Horários disponíveis</label>
  <% if (horarios.length === 0) { %>
    <p class="texto-secundario">Sem horários livres nesta data. Tente outra.</p>
  <% } else { %>
    <div class="grade-horarios">
      <% horarios.forEach(function (h) { %>
        <a class="opcao-horario"
           href="/agendar/dados?servicoIds=<%= servicoIdsStr %>&barbeiroId=<%= barbeiro.id %>&data=<%= dataSel %>&hora=<%= h %><%= assinatura ? '&assinatura=' + assinatura.id : '' %>">
          <%= h %>
        </a>
      <% }) %>
    </div>
  <% } %>
<% } %>
