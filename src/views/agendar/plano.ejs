<a href="/agendar" class="link-voltar">← Agendar normalmente</a>

<div class="cabecalho-pagina">
  <h1>Tem um plano?</h1>
  <p class="texto-secundario">Informe seu telefone para usar seu plano no agendamento.</p>
</div>

<div class="card">
  <form method="GET" action="/agendar/plano" class="form">
    <div class="campo">
      <label for="telefone">Telefone</label>
      <input id="telefone" name="telefone" inputmode="tel" placeholder="(51) 99999-9999"
             value="<%= telefoneDigitado %>" required autofocus />
    </div>
    <button class="btn btn-primario btn-bloco" type="submit">Verificar plano</button>
  </form>
</div>

<% if (resultado) { %>
  <% if (resultado.assinaturas.length === 0) { %>
    <div class="alerta alerta-aviso mt-16">Nenhum plano ativo encontrado para esse telefone.</div>
    <a href="/agendar" class="btn btn-secundario btn-bloco">Agendar sem plano</a>
  <% } else { %>
    <div class="cabecalho-pagina mt-24">
      <h2>Olá, <%= resultado.cliente.nome %>!</h2>
      <p class="texto-secundario">Escolha o plano para agendar:</p>
    </div>
    <div class="lista-opcoes">
      <% resultado.assinaturas.forEach(function (a) { %>
        <a class="opcao-selecionavel opcao-servico"
           href="<%= a.plano.servicoId ? '/agendar/barbeiro?servicoId=' + a.plano.servicoId + '&assinatura=' + a.id : '/agendar?assinatura=' + a.id %>">
          <span class="opcao-info">
            <span class="opcao-nome"><%= a.plano.nome %></span>
            <span class="texto-sutil">
              <%= a.plano.tipo === 'ilimitado' ? 'Ilimitado · só seg–qui' : a.usosRestantes + ' uso(s) restante(s)' %>
              · até <%= fmtData(a.dataFim) %><%= a.plano.servico ? ' · ' + a.plano.servico.nome : '' %>
            </span>
          </span>
          <span class="opcao-meta"><span class="opcao-valor">Usar →</span></span>
        </a>
      <% }) %>
    </div>
  <% } %>
<% } %>
