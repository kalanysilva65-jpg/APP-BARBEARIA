<a href="/agendar/horario?servicoIds=<%= servicoIdsStr %>&barbeiroId=<%= barbeiro.id %>&data=<%= data %><%= assinatura ? '&assinatura=' + assinatura.id : '' %>"
   class="link-voltar">← Voltar</a>

<div class="cabecalho-pagina">
  <h1>Seus dados</h1>
  <p>Quase lá</p>
</div>

<form method="POST" action="/agendar/confirmar" class="form">
  <input type="hidden" name="servicoIds" value="<%= servicoIdsStr %>" />
  <input type="hidden" name="barbeiroId" value="<%= barbeiro.id %>" />
  <input type="hidden" name="data" value="<%= data %>" />
  <input type="hidden" name="hora" value="<%= hora %>" />
  <% if (assinatura) { %><input type="hidden" name="assinatura" value="<%= assinatura.id %>" /><% } %>

  <div class="campo">
    <label for="cliente_nome">Nome completo</label>
    <input id="cliente_nome" name="cliente_nome" placeholder="Seu nome" required
           value="<%= assinatura ? assinatura.cliente.nome : '' %>" <%= assinatura ? 'readonly' : 'autofocus' %> />
  </div>
  <div class="campo">
    <label for="cliente_telefone">Telefone</label>
    <input id="cliente_telefone" name="cliente_telefone" placeholder="(00) 00000-0000" required
           value="<%= assinatura ? fmtTelefone(assinatura.cliente.telefone) : '' %>" <%= assinatura ? 'readonly' : '' %> />
  </div>
  <% if (!assinatura) { %>
  <div class="campo">
    <label for="cliente_nascimento">Data de nascimento (opcional)</label>
    <input id="cliente_nascimento" type="date" name="cliente_nascimento" />
  </div>
  <% } %>

  <div class="resumo-titulo mt-24">Resumo</div>
  <div class="resumo">
    <% if (servicos.length === 1) { %>
      <div class="resumo-linha"><span class="texto-sutil">Serviços</span><span><%= servicos[0].nome %></span></div>
    <% } else { %>
      <div class="resumo-linha"><span class="texto-sutil">Serviços</span><span><%= servicos.map(function (s) { return s.nome; }).join(', ') %></span></div>
    <% } %>
    <div class="resumo-linha"><span class="texto-sutil">Barbeiro</span><span><%= barbeiro.nome %></span></div>
    <div class="resumo-linha"><span class="texto-sutil">Data</span><span><%= dataExtenso %></span></div>
    <div class="resumo-linha"><span class="texto-sutil">Horário</span><span><%= hora %></span></div>
    <% if (assinatura) { %>
      <div class="resumo-linha"><span class="texto-sutil">Plano</span><span><%= assinatura.plano.nome %></span></div>
      <div class="resumo-linha total"><span>Total</span><span>Incluso no plano (<%= fmtBRL(0) %>)</span></div>
    <% } else { %>
      <div class="resumo-linha total"><span>Total</span><span><%= fmtBRL(valorTotal) %></span></div>
    <% } %>
  </div>

  <div class="acao-central">
    <button class="btn btn-primario btn-bloco" type="submit">Confirmar agendamento</button>
  </div>
</form>
