<% if (assinatura) { %>
  <div class="alerta alerta-sucesso">
    Usando o plano <strong><%= assinatura.plano.nome %></strong><%= assinatura.usosRestantes !== null ? ' · ' + assinatura.usosRestantes + ' uso(s) restante(s)' : ' · ilimitado (seg–qui)' %>.
    <a href="/agendar">Agendar sem plano</a>
  </div>
<% } else { %>
  <a href="/agendar/plano" class="plano-banner">
    <span class="plano-esquerda">
      <svg class="plano-coroa" width="24" height="22" viewBox="0 0 24 24" fill="#e0a92e" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 7l4.6 3.3L12 3.6l5.4 6.7L22 7l-1.9 11.2H3.9L2 7z"/>
        <rect x="4" y="19.4" width="16" height="2.4" rx="1.2"/>
      </svg>
      <span class="plano-label">Tem um plano?</span>
    </span>
    <span class="btn-plano-topo">Clique aqui</span>
  </a>
<% } %>

<div class="cabecalho-pagina">
  <h1>Escolha o serviço</h1>
  <% if (!assinatura) { %>
    <p class="texto-secundario">Selecione um ou mais serviços.</p>
  <% } else { %>
    <p class="texto-secundario">Selecione o serviço do seu plano.</p>
  <% } %>
</div>

<%
  // Ícone de relógio reutilizado na duração dos cards.
  function iconeRelogio() { return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>'; }
%>

<% if (assinatura) { %>
  <%/* Plano: seleção única direta por link */%>
  <div class="grade-opcoes">
    <% servicos.forEach(function (s) { %>
      <a class="card-opcao opcao-toggle" href="/agendar/barbeiro?servicoIds=<%= s.id %>&assinatura=<%= assinatura.id %>">
        <div class="card-opcao-nome"><%= s.nome %></div>
        <% var descServico = s.descricao || (s.categoria ? s.categoria.nome : ''); %>
        <% if (descServico) { %><div class="card-opcao-desc"><%= descServico %></div><% } %>
        <div class="card-opcao-rodape">
          <span class="card-opcao-valor">Incluso</span>
          <% if (s.duracaoMin > 0) { %><span class="card-opcao-duracao"><%- iconeRelogio() %> <%= s.duracaoMin %> min</span><% } %>
        </div>
      </a>
    <% }) %>
  </div>
<% } else { %>
  <%/* Sem plano: multi-select com JS */%>
  <form id="form-servicos" action="/agendar/barbeiro" method="GET" onsubmit="return validarSelecao()">
    <input type="hidden" name="servicoIds" id="servicoIds-input" value="" />

    <div class="grade-opcoes" id="lista-servicos">
      <% servicos.forEach(function (s) { %>
        <div class="card-opcao opcao-toggle" data-id="<%= s.id %>" onclick="toggleServico(this)">
          <div class="card-opcao-nome"><%= s.nome %></div>
          <% var descServico = s.descricao || (s.categoria ? s.categoria.nome : ''); %>
        <% if (descServico) { %><div class="card-opcao-desc"><%= descServico %></div><% } %>
          <div class="card-opcao-rodape">
            <span class="card-opcao-valor"><%= fmtBRL(s.valor) %></span>
            <% if (s.duracaoMin > 0) { %><span class="card-opcao-duracao"><%- iconeRelogio() %> <%= s.duracaoMin %> min</span><% } %>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="acao-central">
      <button class="btn btn-primario btn-pill" type="submit" id="btn-continuar" disabled>
        Continuar
      </button>
    </div>
  </form>

  <script>
    const selecionados = new Set();
    function toggleServico(el) {
      const id = el.dataset.id;
      if (selecionados.has(id)) {
        selecionados.delete(id);
        el.classList.remove('selecionado');
      } else {
        selecionados.add(id);
        el.classList.add('selecionado');
      }
      document.getElementById('servicoIds-input').value = Array.from(selecionados).join(',');
      document.getElementById('btn-continuar').disabled = selecionados.size === 0;
    }
    function validarSelecao() {
      return selecionados.size > 0;
    }
  </script>
<% } %>

<% if (servicos.length === 0) { %>
  <div class="card"><p class="texto-secundario">Nenhum serviço disponível no momento.</p></div>
<% } %>
