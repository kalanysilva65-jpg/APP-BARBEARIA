<% if (assinatura) { %>
  <div class="alerta alerta-sucesso">
    Usando o plano <strong><%= assinatura.plano.nome %></strong><%= assinatura.usosRestantes !== null ? ' · ' + assinatura.usosRestantes + ' uso(s) restante(s)' : ' · ilimitado (seg–qui)' %>.
    <a href="/agendar">Agendar sem plano</a>
  </div>
<% } else { %>
  <a href="/agendar/plano" class="plano-banner">
    <span class="plano-label">Tem um plano?</span>
    <span class="btn-plano-topo">
      Clique aqui
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="1" y1="5" x2="11" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M7.5 1.5 L11.5 5 L7.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
<% } %>

<div class="cabecalho-pagina">
  <h1>Escolha o serviço</h1>
  <p class="texto-secundario">Selecione o que você deseja agendar.</p>
</div>

<div class="lista-opcoes">
  <% servicos.forEach(function (s) { %>
    <a class="opcao-selecionavel opcao-servico"
       href="/agendar/barbeiro?servicoId=<%= s.id %><%= assinatura ? '&assinatura=' + assinatura.id : '' %>">
      <span class="opcao-esquerda">
        <% if (s.fotoUrl) { %><img class="opcao-thumb" src="<%= s.fotoUrl %>" alt="" /><% } %>
        <span class="opcao-info">
          <span class="opcao-nome"><%= s.nome %></span>
          <% if (s.categoria) { %><span class="texto-sutil"><%= s.categoria.nome %></span><% } %>
        </span>
      </span>
      <span class="opcao-meta">
        <% if (assinatura) { %>
          <span class="opcao-valor">Incluso</span>
        <% } else { %>
          <span class="opcao-valor"><%= fmtBRL(s.valor) %></span>
        <% } %>
        <% if (s.duracaoMin > 0) { %><span class="texto-sutil"><%= s.duracaoMin %> min</span><% } %>
      </span>
    </a>
  <% }) %>
</div>

<% if (servicos.length === 0) { %>
  <div class="card"><p class="texto-secundario">Nenhum serviço disponível no momento.</p></div>
<% } %>
