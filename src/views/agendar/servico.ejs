<%
  function _diasPlanoLabelServico(diasStr) {
    var DIAS = ['dom', 'seg', 'ter', 'qua', 'qui', 'sex', 'sáb'];
    var dias = String(diasStr || '').split(',').map(Number).filter(function (n) { return !isNaN(n); }).sort(function (a, b) { return a - b; });
    if (dias.length === 7) return 'todos os dias';
    var corrido = dias.every(function (d, i) { return i === 0 || d === dias[i - 1] + 1; });
    if (corrido && dias.length > 1) return DIAS[dias[0]] + '–' + DIAS[dias[dias.length - 1]];
    return dias.map(function (d) { return DIAS[d]; }).join(', ');
  }
%>
<% if (assinatura) { %>
  <div class="alerta alerta-sucesso mb-24">
    Usando o plano <strong><%= assinatura.plano.nome %></strong><%= assinatura.usosRestantes !== null ? ' · ' + assinatura.usosRestantes + ' uso(s) restante(s)' : ' · ilimitado (' + _diasPlanoLabelServico(assinatura.plano.diasSemana) + ')' %>.
    <a href="/agendar">Agendar sem plano</a>
  </div>
<% } %>

<div class="cabecalho-pagina">
  <h1>Escolha o serviço</h1>
</div>

<% if (assinatura) { %>
  <%/* Plano: seleção única direta por link */%>
  <div class="grade-opcoes">
    <% servicos.forEach(function (s) { %>
      <a class="card-opcao opcao-toggle" href="/agendar/barbeiro?servicoIds=<%= s.id %>&assinatura=<%= assinatura.id %>">
        <div>
          <div class="card-opcao-nome"><%= s.nome %></div>
          <% if (s.duracaoMin > 0) { %><div class="card-opcao-duracao"><%= s.duracaoMin %> MIN</div><% } %>
        </div>
        <span class="card-opcao-valor">Incluso</span>
      </a>
    <% }) %>
  </div>
<% } else { %>
  <%/* Sem plano: multi-select com JS */%>
  <form id="form-servicos" action="/agendar/barbeiro" method="GET" onsubmit="return validarSelecao()">
    <input type="hidden" name="servicoIds" id="servicoIds-input" value="" />

    <div class="grade-opcoes" id="lista-servicos">
      <% servicos.forEach(function (s) { %>
        <div class="card-opcao opcao-toggle" data-id="<%= s.id %>" data-valor="<%= s.valor %>" onclick="toggleServico(this)">
          <div>
            <div class="card-opcao-nome"><%= s.nome %></div>
            <% if (s.duracaoMin > 0) { %><div class="card-opcao-duracao"><%= s.duracaoMin %> MIN</div><% } %>
          </div>
          <span class="card-opcao-valor"><%= fmtBRL(s.valor) %></span>
        </div>
      <% }) %>
    </div>

    <a href="/agendar/plano" class="link-plano mt-24">Já tem um plano? Consultar</a>

    <div class="acao-central">
      <button class="btn btn-primario btn-bloco" type="submit" id="btn-continuar" disabled>
        Selecione ao menos um serviço
      </button>
    </div>
  </form>

  <script>
    const selecionados = new Set();
    const precos = {};
    document.querySelectorAll('#lista-servicos .card-opcao').forEach(function (el) {
      precos[el.dataset.id] = Number(el.dataset.valor);
    });
    function fmtBRL(centavos) {
      return 'R$ ' + (centavos / 100).toLocaleString('pt-BR', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
    }
    function toggleServico(el) {
      const id = el.dataset.id;
      if (selecionados.has(id)) {
        selecionados.delete(id);
        el.classList.remove('selecionado');
      } else {
        selecionados.add(id);
        el.classList.add('selecionado');
      }
      document.getElementById('servicoIds-input').value = Array.from(selecionados).join(',');
      const btn = document.getElementById('btn-continuar');
      btn.disabled = selecionados.size === 0;
      if (selecionados.size === 0) {
        btn.textContent = 'Selecione ao menos um serviço';
      } else {
        const total = Array.from(selecionados).reduce(function (s, id) { return s + precos[id]; }, 0);
        btn.textContent = 'Continuar — ' + fmtBRL(total);
      }
    }
    function validarSelecao() {
      return selecionados.size > 0;
    }
  </script>
<% } %>

<% if (servicos.length === 0) { %>
  <p class="texto-secundario">Nenhum serviço disponível no momento.</p>
<% } %>
