<a href="/agendar<%= assinatura ? '?assinatura=' + assinatura.id : '' %>" class="link-voltar">← Voltar</a>

<div class="cabecalho-pagina">
  <h1>Escolha o barbeiro</h1>
  <p class="texto-secundario">
    <% if (servicos.length === 1) { %>
      <%= servicos[0].nome %> · <%= assinatura ? 'incluso no plano' : fmtBRL(valorTotal) %>
    <% } else { %>
      <%= servicos.length %> serviços · <%= fmtBRL(valorTotal) %>
    <% } %>
  </p>
</div>

<div class="lista-opcoes">
  <% barbeiros.forEach(function (b) { %>
    <a class="opcao-selecionavel opcao-barbeiro"
       href="/agendar/horario?servicoIds=<%= servicoIdsStr %>&barbeiroId=<%= b.id %><%= assinatura ? '&assinatura=' + assinatura.id : '' %>">
      <span class="avatar"><%= b.nome.charAt(0).toUpperCase() %></span>
      <span class="opcao-nome"><%= b.nome %></span>
    </a>
  <% }) %>
</div>
