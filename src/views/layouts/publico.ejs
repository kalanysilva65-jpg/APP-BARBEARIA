<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof titulo !== 'undefined' ? titulo + ' · ' : '' %>Andrade Barbearia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="/css/tema-minimal.css" />
  </head>
  <body class="tela-publica">
    <header class="topo-publico">
      <div class="container-estreito">
        <a href="/agendar" class="logo-flowbarber logo-flowbarber--sm"><span class="lf">flow</span><span class="lb">barber</span><span class="ld">.</span></a>
      </div>
    </header>

    <main class="container-estreito conteudo-publico">
      <% if (typeof passo !== 'undefined' && passo >= 1 && passo <= 4) { %>
        <%- include('../partials/passos', { passo: passo }) %>
      <% } %>
      <%- include('../partials/flash') %>
      <%- body %>
    </main>

    <footer class="rodape-publico">
      <div class="container-estreito">
        <a href="/login" class="texto-sutil">Acesso da equipe →</a>
      </div>
    </footer>
  </body>
</html>
