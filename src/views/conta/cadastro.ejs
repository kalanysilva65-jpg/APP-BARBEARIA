<%/* Andaime da Fase 0 — substituído pelo design "Cortavo" na Fase 1. */%>
<div class="card auth-card">
  <div class="auth-cabecalho">
    <div class="logo-flowbarber logo-flowbarber--lg" style="justify-content:center;margin-bottom:4px;"><span class="lf">Cortavo</span></div>
    <p class="texto-secundario">Criar sua conta</p>
  </div>

  <form method="POST" action="/conta/cadastro" class="form">
    <div class="campo">
      <label for="nome">Nome</label>
      <input type="text" id="nome" name="nome" placeholder="Seu nome" required autofocus />
    </div>
    <div class="campo">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" placeholder="seu@email.com" required />
    </div>
    <div class="campo">
      <label for="telefone">Telefone <span class="texto-sutil">(opcional)</span></label>
      <input type="tel" id="telefone" name="telefone" placeholder="(11) 90000-0000" />
    </div>
    <div class="campo">
      <label for="senha">Senha <span class="texto-sutil">(mín. 6 caracteres)</span></label>
      <input type="password" id="senha" name="senha" placeholder="••••••••" minlength="6" required />
    </div>
    <button class="btn btn-primario btn-bloco" type="submit">Criar conta</button>
  </form>

  <div style="text-align:center;margin-top:16px;">
    <a href="/conta/entrar" class="texto-secundario">Já tem conta? Entrar</a>
  </div>
</div>
