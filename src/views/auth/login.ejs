<div class="card auth-card">
  <div class="auth-cabecalho">
    <div class="logo-flowbarber logo-flowbarber--lg" style="justify-content:center;margin-bottom:4px;"><span class="lf">flow</span><span class="lb">barber</span><span class="ld">.</span></div>
    <p class="texto-secundario">Acesso da equipe</p>
  </div>

  <form method="POST" action="/login" class="form">
    <div class="campo">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" placeholder="seu@email.com" required autofocus />
    </div>

    <div class="campo">
      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" placeholder="••••••••" required />
    </div>

    <button class="btn btn-primario btn-bloco" type="submit">Entrar</button>
  </form>
</div>
