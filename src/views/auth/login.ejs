<div class="card auth-card">
  <div class="auth-cabecalho">
    <%/* A logo configurada (marcaLogoUrl) só aparece no agendamento público —
       aqui no login da equipe é sempre a marca em texto. */%>
    <% if (barbearia) { %>
      <div class="logo-flowbarber logo-flowbarber--lg" style="justify-content:center;margin-bottom:4px;"><span class="lf"><%= barbearia.nome %></span></div>
    <% } else { %>
      <div class="logo-flowbarber logo-flowbarber--lg" style="justify-content:center;margin-bottom:4px;"><span class="lf">Cortavo</span></div>
    <% } %>
    <p class="texto-secundario"><%= barbearia ? barbearia.nome : 'Acesso da equipe' %></p>
  </div>

  <form method="POST" action="/login" class="form">
    <div class="campo">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" placeholder="seu@email.com" required autofocus />
    </div>

    <div class="campo">
      <label for="senha">Senha</label>
      <input type="password" id="senha" name="senha" placeholder="••••••••" required />
    </div>

    <button class="btn btn-primario btn-bloco" type="submit">Entrar</button>
  </form>

  <div style="text-align:center;margin-top:20px;">
    <span class="powered-by-marca texto-sutil">Desenvolvido por <span class="logo-flowbarber logo-flowbarber--xs"><span class="lf">Cortavo</span></span></span>
  </div>
</div>
